---
import '../styles/global.css';
import { useTranslations, getAlternateLang, localePath } from '../i18n';
import type { Lang } from '../i18n';

export interface Props {
  title: string;
  description?: string;
  lang: Lang;
  currentPath?: string; // e.g. '/problem', '/raft', '/'
}

const {
  title,
  description = 'Learn distributed consensus and the Raft algorithm interactively.',
  lang,
  currentPath = '/',
} = Astro.props;

const t = useTranslations(lang);
const base = import.meta.env.BASE_URL;
const altLang = getAlternateLang(lang);
const altHref = localePath(altLang, currentPath, base);
const navLinks = [
  { key: 'problem',    path: '/problem' },
  { key: 'raft',       path: '/raft' },
  { key: 'wild',       path: '/in-the-wild' },
  { key: 'implementation', path: '/implementation' },
  { key: 'resources',  path: '/resources' },
  { key: 'visualizer', path: '/visualizer' },
] as const;
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — {lang === 'es' ? 'Consenso Distribuido' : 'Distributed Consensus'}</title>
    <meta name="description" content={description} />
    <link rel="alternate" hreflang={altLang} href={altHref} />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body class="min-h-screen bg-slate-950 text-slate-200">

    <nav class="sticky top-0 z-50 bg-slate-950/90 backdrop-blur border-b border-slate-800">
      <div class="max-w-6xl mx-auto px-4 py-3 flex items-center justify-between">
        <a href={localePath(lang, '/', base)} class="font-bold text-sky-400 text-sm tracking-wide hover:text-sky-300 transition font-mono">
          DCL
        </a>
        <div class="flex items-center gap-5 text-sm">
          {navLinks.map(({ key, path }) => (
            <a
              href={localePath(lang, path, base)}
              class={`transition ${currentPath === path ? 'text-slate-200' : 'text-slate-400 hover:text-slate-200'}`}
            >
              {t.nav[key as keyof typeof t.nav]}
            </a>
          ))}
          <!-- Lang switcher -->
          <a
            href={altHref}
            class="px-2.5 py-1 rounded text-xs font-mono bg-slate-800 hover:bg-slate-700 text-slate-300 border border-slate-700 transition"
            title={altLang === 'es' ? 'Cambiar a español' : 'Switch to English'}
          >
            {altLang === 'es' ? 'ES' : 'EN'}
          </a>
        </div>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <footer class="border-t border-slate-800 mt-24 py-8 text-center text-slate-500 text-sm">
      <p>
        {t.footer.built} ·
        <a href="https://raft.github.io/" target="_blank" class="text-sky-500 hover:text-sky-400">{t.footer.paper}</a> ·
        <a href="https://github.com/DevArKaDiA/distributed-consensus-learning" target="_blank" class="text-sky-500 hover:text-sky-400">GitHub</a>
      </p>
    </footer>
  </body>
</html>
