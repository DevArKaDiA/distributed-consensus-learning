  // ─── KV Terminal ──────────────────────────────────────────────────────────────

  const kvStore = new Map();
  const kvOutput = document.getElementById('kv-output');
  const kvInput = document.getElementById('kv-input');
  const kvTerminal = document.getElementById('kv-terminal');
  const MAX_SCROLLBACK = 50;

  function kvPrint(line, cls = 'text-slate-300') {
    const div = document.createElement('div');
    div.className = `font-mono text-sm whitespace-pre ${cls}`;
    div.textContent = line;
    kvOutput.appendChild(div);
    while (kvOutput.children.length > MAX_SCROLLBACK) kvOutput.removeChild(kvOutput.firstChild);
