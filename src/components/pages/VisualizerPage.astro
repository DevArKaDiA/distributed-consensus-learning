---
import Base from '../../layouts/Base.astro';
import { useTranslations } from '../../i18n';
import type { Lang } from '../../i18n';

export interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);
const tv = t.visualizer;

// Strings injected into the script via define:vars
const isEs = lang === 'es';
const strings = {
  // Narration messages
  n_election_timeout:  isEs ? `no escuchó al líder — iniciando elección (término ` : `didn't hear from a leader — starting election (term `,
  n_request_vote:      isEs ? `solicita votos a los pares` : `is requesting votes from peers`,
  n_vote_granted:      isEs ? `concede voto a` : `grants vote to`,
  n_vote_denied:       isEs ? `deniega voto a` : `denies vote to`,
  n_split_vote:        isEs ? `Voto dividido — sin ganador. Los nodos harán timeout y reintentarán` : `Split vote — no winner. Nodes will timeout and retry`,
  n_leader_elected:    isEs ? `gana la elección con` : `wins election with`,
  n_leader_elected2:   isEs ? `votos — ahora líder (término ` : `votes — now leader (term `,
  n_heartbeat:         isEs ? `envía heartbeats a los seguidores — reiniciando sus temporizadores` : `sends heartbeats to followers — resetting their timers`,
  n_sim_started:       isEs ? `Simulación iniciada — esperando primer timeout de elección…` : `Simulation started — waiting for first election timeout…`,
  n_node_joining:      isEs ? `se une como learner — sincronizando con el líder` : `joining as learner — catching up with leader`,
  n_node_joined_ok:    isEs ? `sincronizado y promovido a votante (término ` : `caught up and promoted to voter (term `,
  n_node_joined_wait:  isEs ? `listo — esperando un líder para sincronizar` : `ready — waiting for a leader to sync`,
  n_node_removed_leader: isEs ? `eliminado (era líder) — elección pendiente` : `removed (was leader) — election pending`,
  n_node_removed:      isEs ? `eliminado del clúster` : `removed from cluster`,
  // Node detail labels
  d_state:    isEs ? 'estado'            : 'state',
  d_term:     isEs ? 'término'           : 'term',
  d_voted_for: isEs ? 'votadoPor'        : 'votedFor',
  d_none:     isEs ? 'ninguno'           : 'none',
  d_commit:   isEs ? 'índiceConfirmado'  : 'commitIndex',
  d_log:      isEs ? 'log'               : 'log',
  d_empty_log: isEs ? '(log vacío)'      : '(empty log)',
  d_node_detail_empty: isEs ? 'Haz clic en un nodo para inspeccionar su estado.' : 'Click a node to inspect its state.',
  // KV terminal
  kv_welcome1: isEs ? '  distributed-kv v1.0  —  almacén clave/valor con Raft' : '  distributed-kv v1.0  —  Raft-backed key/value store',
  kv_welcome2: isEs ? '  escribe help para los comandos disponibles' : '  type help for available commands',
  kv_welcome3: isEs ? '  usa la consola admin para matar/revivir nodos o crear particiones' : '  use the cluster-admin shell below to kill/revive nodes or create partitions',
  kv_no_leader: isEs ? '  ✗ sin líder — clúster no disponible' : '  ✗ no leader — cluster unavailable',
  // Admin terminal
  adm_welcome1: isEs ? '  cluster-admin v1.0  —  control elevado del clúster' : '  cluster-admin v1.0  —  elevated cluster control',
  adm_welcome2: isEs ? '  ⚠ las mutaciones se aplican al estado de la simulación en vivo' : '  ⚠ mutations apply to live simulation state',
  adm_welcome3: isEs ? '  escribe help para los comandos disponibles' : '  type help for available commands',
  // UI labels (injected into HTML initial state via script or used in script)
  ui_live: isEs ? 'En Vivo' : 'Live',
  // KV help output
  kv_help_header:   isEs ? '  Comandos:'                                          : '  Commands:',
  kv_help_set:      isEs ? '    set <clave> <valor>   — escribir una clave'       : '    set <key> <value>   — write a key',
  kv_help_get:      isEs ? '    get <clave>           — leer clave del líder'     : '    get <key>           — read a key from leader',
  kv_help_del:      isEs ? '    del <clave>           — eliminar una clave'       : '    del <key>           — delete a key',
  kv_help_keys:     isEs ? '    keys                 — listar claves confirmadas' : '    keys                — list all committed keys',
  kv_help_state:    isEs ? '    state                — mostrar estado del clúster': '    state               — show cluster state',
  kv_help_clear:    isEs ? '    clear                — limpiar terminal'          : '    clear               — clear terminal',
  kv_help_help:     isEs ? '    help                 — este mensaje'              : '    help                — this message',
  kv_empty_store:   isEs ? '  (almacén vacío)' : '  (empty store)',
  kv_usage_get:     isEs ? '  uso: get <clave>' : '  usage: get <key>',
  kv_usage_set:     isEs ? '  uso: set <clave> <valor>' : '  usage: set <key> <value>',
  kv_usage_del:     isEs ? '  uso: del <clave>' : '  usage: del <key>',
  kv_unknown_cmd:   isEs ? '  ✗ comando desconocido: ' : '  ✗ unknown command: ',
  kv_reading_from:  isEs ? '  → leyendo del líder' : '  → reading from leader',
  kv_leader_recv:   isEs ? '  → líder' : '  → leader',
  kv_received:      isEs ? ' recibió ' : ' received ',
  kv_replicating:   isEs ? '  → replicando a ' : '  → replicating to ',
  kv_majority_ack:  isEs ? '  → ACK de mayoría (' : '  → majority ACK (',
  kv_committed_set: isEs ? '  ✓ confirmado: ' : '  ✓ committed: ',
  kv_committed_del: isEs ? '  ✓ confirmado: eliminado ' : '  ✓ committed: deleted ',
  kv_cluster_term:  isEs ? '  término clúster: ' : '  cluster term: ',
  kv_role_leader:   isEs ? ' [LÍDER]' : ' [LEADER]',
  kv_role_dead:     isEs ? ' [CAÍDO]' : ' [DEAD]',
  kv_key_not_found: isEs ? '  ✗ clave no encontrada: ' : '  ✗ key not found: ',
  // Admin help output
  adm_help_header:  isEs ? '  Comandos:'                                                          : '  Commands:',
  adm_help_kill:    isEs ? '    kill <nodoId>         — crashear un nodo (ej. kill N3)'           : '    kill <nodeId>          — crash a node (e.g. kill N3)',
  adm_help_revive:  isEs ? '    revive <nodoId>       — revivir nodo caído como seguidor'         : '    revive <nodeId>        — bring a dead node back as follower',
  adm_help_part:    isEs ? '    partition <ids>       — aislar nodos (ej. partition N1,N2)'       : '    partition <ids>        — isolate nodes (e.g. partition N1,N2)',
  adm_help_heal:    isEs ? '    heal                  — eliminar todas las particiones'           : '    heal                   — remove all partitions',
  adm_help_quorum:  isEs ? '    quorum                — estado del quórum'                       : '    quorum                 — quorum status',
  adm_help_leader:  isEs ? '    leader                — líder actual y término'                  : '    leader                 — current leader and term',
  adm_help_term:    isEs ? '    term                  — término actual del clúster'              : '    term                   — current cluster term',
  adm_help_logs:    isEs ? '    logs                  — longitud de log de cada nodo'            : '    logs                   — log lengths for all nodes',
  adm_help_status:  isEs ? '    status                — resumen completo del clúster'            : '    status                 — full cluster overview',
  adm_help_clear:   isEs ? '    clear                 — limpiar terminal'                        : '    clear                  — clear terminal',
  adm_help_help:    isEs ? '    help                  — este mensaje'                            : '    help                   — this message',
  // Admin kill output
  adm_usage_kill:   isEs ? '  uso: kill <nodoId>  (ej. kill N3)'   : '  usage: kill <nodeId>  (e.g. kill N3)',
  adm_not_found:    isEs ? ' no encontrado'      : ' not found',
  adm_already_dead: isEs ? ' ya está caído'      : ' is already dead',
  adm_is_dead:      isEs ? ' está caído'         : ' is dead',
  adm_leader_lost:  isEs ? ' — líder perdido'    : ' — leader lost',
  adm_quorum_lost:  isEs ? '  ✗ quórum perdido — clúster no disponible' : '  ✗ quorum lost — cluster unavailable',
  adm_quorum_intact: isEs ? '  quórum intacto — ' : '  quorum intact — ',
  adm_alive_suffix: isEs ? ' activos'   : ' alive',
  // Admin revive output
  adm_usage_revive:   isEs ? '  uso: revive <nodoId>  (ej. revive N3)' : '  usage: revive <nodeId>  (e.g. revive N3)',
  adm_not_dead:       isEs ? ' no está caído (estado: ' : ' is not dead (state: ',
  adm_rejoined:       isEs ? '  ✓ ' : '  ✓ ',
  adm_rejoined_as:    isEs ? ' se reincorporó como seguidor (término ' : ' rejoined as follower (term ',
  // Admin partition/heal output
  adm_usage_part:     isEs ? '  uso: partition N1,N2  (separados por coma o espacio)' : '  usage: partition N1,N2  (comma or space separated)',
  adm_isolated:       isEs ? ' aislado — paquetes hacia/desde este nodo serán descartados' : ' isolated — packets to/from this node will be dropped',
  adm_skipped:        isEs ? ' no encontrado — omitido' : ' not found — skipped',
  adm_no_partitions:  isEs ? '  sin particiones activas' : '  no active partitions',
  adm_healed:         isEs ? '  partición sanada — restaurados: ' : '  partition healed — restored: ',
  // Admin quorum/leader/term/logs/status output
  adm_total_nodes:    isEs ? '  nodos totales : ' : '  total nodes : ',
  adm_alive:          isEs ? '  activos       : ' : '  alive       : ',
  adm_majority:       isEs ? '  mayoría       : ' : '  majority    : ',
  adm_quorum_label:   isEs ? '  quórum        : ' : '  quorum      : ',
  adm_no_leader:      isEs ? '  sin líder — clúster en elección o todos caídos' : '  no leader — cluster in election or all dead',
  adm_leader_label:   isEs ? '  líder: '     : '  leader: ',
  adm_cluster_term:   isEs ? '  término clúster: ' : '  cluster term: ',
  adm_logs_header:    isEs ? '  nodo   log   indiceConf   estado' : '  node   log   commitIndex  state',
  adm_status_term:    isEs ? '  término clúster : ' : '  cluster term : ',
  adm_status_leader:  isEs ? '  líder         : ' : '  leader       : ',
  adm_status_none:    isEs ? 'ninguno' : 'none',
  adm_status_quorum:  isEs ? '  quórum        : ' : '  quorum       : ',
  adm_alive_s:        isEs ? ' activos — mayoría ' : ' alive — majority ',
  adm_ok:             isEs ? ' — OK'    : ' — OK',
  adm_lost:           isEs ? ' — PERDIDO' : ' — LOST',
  adm_partitioned:    isEs ? '  particionados : ' : '  partitioned  : ',
  adm_isolated_tag:   isEs ? ' [AISLADO]' : ' [ISOLATED]',
  adm_unknown_cmd:    isEs ? '  comando desconocido: ' : '  unknown command: ',
  adm_type_help:      isEs ? '  (escribe help)' : '  (type help)',
  // Snapshot / compaction
  adm_help_compact:   isEs ? '    compact               — forzar compactación de log en todos los nodos'      : '    compact               — force log compaction on all nodes',
  adm_compact_done:   isEs ? '  ✓ log compactado — snapshot en índice ' : '  ✓ log compacted — snapshot at index ',
  adm_compact_none:   isEs ? '  nada que compactar (log corto en todos los nodos)' : '  nothing to compact (log short on all nodes)',
  adm_snap_label:     isEs ? '  snapshot @ ' : '  snapshot @ ',
  d_snapshot:         isEs ? 'snapshot' : 'snapshot',
  n_compacting:       isEs ? 'compactando log — descartando entradas confirmadas' : 'compacting log — discarding committed entries',
  n_install_snapshot: isEs ? `recibe InstallSnapshot del líder — saltando catch-up` : `receives InstallSnapshot from leader — skipping catch-up`,
  n_node_joining_snap: isEs ? `se une como learner — el líder tiene snapshot, enviando InstallSnapshot` : `joining as learner — leader has snapshot, sending InstallSnapshot`,
};
---
<Base title={tv.title} {lang} currentPath="/visualizer">

  <!-- Header -->
  <section class="max-w-6xl mx-auto px-4 pt-12 pb-6">
    <h1 class="text-3xl font-bold text-white mb-2">{tv.title}</h1>
    <p class="text-slate-400 text-sm max-w-2xl">{tv.subtitle}</p>
  </section>

  <!-- Controls bar -->
  <section class="max-w-6xl mx-auto px-4 pb-4">
    <div class="bg-slate-900 border border-slate-700 rounded-xl p-3 flex flex-wrap items-center gap-3">

      <!-- Sim Speed -->
      <div class="flex items-center gap-2">
        <span class="text-slate-400 text-xs font-mono">{isEs ? 'Vel. Sim.' : 'Sim Speed'}</span>
        <select id="sel-speed" class="bg-slate-800 border border-slate-600 text-slate-300 text-xs font-mono rounded-lg px-2 py-1">
          <option value="0.25">0.25×</option>
          <option value="0.5" selected>0.5×</option>
          <option value="1">1×</option>
          <option value="2">2×</option>
        </select>
      </div>

      <!-- Divider -->
      <div class="w-px h-6 bg-slate-700 hidden sm:block"></div>

      <!-- Node count controls -->
      <div class="flex items-center gap-2">
        <span class="text-slate-400 text-xs font-mono">{isEs ? 'Nodos' : 'Nodes'}</span>
        <button id="btn-remove-node" class="px-2 py-1 text-xs font-mono bg-slate-700 hover:bg-slate-600 text-slate-300 rounded border border-slate-600 transition">− {isEs ? 'Nodo' : 'Node'}</button>
        <span id="node-count-label" class="text-slate-300 text-xs font-mono w-4 text-center">5</span>
        <button id="btn-add-node" class="px-2 py-1 text-xs font-mono bg-slate-700 hover:bg-slate-600 text-slate-300 rounded border border-slate-600 transition">+ {isEs ? 'Nodo' : 'Node'}</button>
      </div>

      <!-- Divider -->
      <div class="w-px h-6 bg-slate-700 hidden sm:block"></div>

      <!-- Sim status badge -->
      <div class="flex items-center gap-2">
        <span id="sim-status-dot" class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse inline-block"></span>
        <span id="sim-status-text" class="text-emerald-400 text-xs font-mono">{isEs ? 'En Vivo' : 'Live'}</span>
      </div>

      <!-- Reset -->
      <div class="ml-auto">
        <button id="btn-reset" class="px-3 py-1.5 text-xs font-mono bg-red-900/40 hover:bg-red-800/50 text-red-300 rounded-lg border border-red-700/40 transition">
          {tv.reset}
        </button>
      </div>
    </div>
  </section>

  <!-- Main content grid -->
  <section class="max-w-7xl mx-auto px-4 pb-12">
    <div class="grid grid-cols-1 lg:grid-cols-4 gap-4">

      <!-- Left: SVG cluster (takes 3 cols) -->
      <div class="lg:col-span-3 flex flex-col gap-4">

        <!-- SVG canvas -->
        <div class="bg-slate-900 border border-slate-700 rounded-xl p-4">
          <svg id="viz-svg" viewBox="0 0 800 460" class="w-full" style="height:460px">
            <defs>
              <filter id="glow-filter" x="-40%" y="-40%" width="180%" height="180%">
                <feGaussianBlur stdDeviation="4" result="blur"/>
                <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
              </filter>
            </defs>
            <g id="viz-edges"></g>
            <g id="viz-client"></g>
            <g id="viz-nodes"></g>
            <g id="viz-packets"></g>
            <!-- Tooltip -->
            <g id="viz-tooltip" style="display:none; pointer-events:none">
              <rect id="viz-tooltip-bg" rx="6" ry="6" fill="#0f172a" stroke="#334155" stroke-width="1.5"/>
              <text id="viz-tooltip-text" fill="#cbd5e1" font-size="11" font-family="JetBrains Mono, monospace" text-anchor="middle"></text>
            </g>
          </svg>

          <!-- Legend -->
          <div class="mt-3 flex flex-wrap gap-4 text-xs font-mono text-slate-400 px-2">
            <span class="text-slate-500 font-semibold">{tv.legend}:</span>
            <span class="flex items-center gap-1.5"><span class="w-3 h-3 rounded-full bg-indigo-500 inline-block"></span>{tv.legend_follower}</span>
            <span class="flex items-center gap-1.5"><span class="w-3 h-3 rounded-full bg-emerald-500 inline-block"></span>{tv.legend_candidate}</span>
            <span class="flex items-center gap-1.5"><span class="w-3 h-3 rounded-full bg-amber-500 inline-block"></span>{tv.legend_leader}</span>
            <span class="flex items-center gap-1.5"><span class="w-3 h-3 rounded-full bg-slate-600 inline-block"></span>{tv.legend_dead}</span>
            <span class="flex items-center gap-1.5"><span class="w-3 h-3 rounded-full bg-cyan-400 inline-block"></span>{isEs ? 'aprendiz' : 'learner'}</span>
            <span class="flex items-center gap-1.5"><span class="w-3 h-0.5 bg-indigo-400 inline-block rounded"></span>{isEs ? 'temporizador elección' : 'election timer'}</span>
          </div>
        </div>

        <!-- Narration panel -->
        <div class="bg-slate-900 border border-slate-700 rounded-xl p-4">
          <h3 class="text-xs font-mono text-slate-500 uppercase tracking-wider mb-3">{tv.narration_title}</h3>
          <div id="narration-badge" class="hidden mb-2">
            <span id="narration-type" class="px-2 py-0.5 rounded text-xs font-mono bg-sky-900/50 text-sky-300 border border-sky-700/40"></span>
          </div>
          <p id="narration-text" class="text-slate-300 text-sm leading-relaxed">{tv.narration_empty}</p>
        </div>

      </div>

      <!-- Right: Node detail + Event log (1 col) -->
      <div class="flex flex-col gap-4">

        <!-- Node detail panel -->
        <div class="bg-slate-900 border border-slate-700 rounded-xl p-4">
          <h3 class="text-xs font-mono text-slate-500 uppercase tracking-wider mb-3">{tv.node_detail_title}</h3>
          <div id="node-detail">
            <p class="text-slate-500 text-xs">{tv.node_detail_empty}</p>
          </div>
        </div>

        <!-- Event log -->
        <div class="bg-slate-900 border border-slate-700 rounded-xl p-4 flex-1">
          <h3 class="text-xs font-mono text-slate-500 uppercase tracking-wider mb-3">{tv.event_log_title}</h3>
          <div id="event-log" class="space-y-1 max-h-80 overflow-y-auto pr-1"></div>
        </div>

      </div>
    </div>
  </section>

  <!-- Terminals row: KV + Admin side by side on large screens -->
  <section class="max-w-7xl mx-auto px-4 pb-12">
    <div class="grid grid-cols-1 xl:grid-cols-2 gap-4">

  <!-- KV Store Terminal -->
    <div class="bg-black border border-slate-700 rounded-xl overflow-hidden font-mono" id="kv-terminal">
      <!-- Terminal header -->
      <div class="flex items-center gap-2 px-4 py-2.5 bg-slate-900 border-b border-slate-700">
        <span class="w-3 h-3 rounded-full bg-red-500 opacity-70"></span>
        <span class="w-3 h-3 rounded-full bg-amber-500 opacity-70"></span>
        <span class="w-3 h-3 rounded-full bg-green-500 opacity-70"></span>
        <span class="text-slate-400 text-xs ml-3">distributed-kv — {isEs ? 'conectado al clúster' : 'connected to cluster'}</span>
        <span class="ml-auto text-slate-600 text-xs">{isEs ? 'escribe' : 'type'} <span class="text-slate-400">help</span> {isEs ? 'para comandos' : 'for commands'}</span>
      </div>
      <!-- Output area -->
      <div id="kv-output" class="h-56 overflow-y-auto px-4 py-3 space-y-0.5 text-sm leading-5" style="scrollbar-color:#334155 #000"></div>
      <!-- Input line -->
      <div class="flex items-center gap-2 px-4 py-2.5 border-t border-slate-800">
        <span class="text-green-400 select-none">$</span>
        <input id="kv-input" type="text" autocomplete="off" spellcheck="false"
          class="flex-1 bg-transparent text-green-300 text-sm outline-none placeholder-slate-600 caret-green-400"
          placeholder={isEs ? 'set clave valor  |  get clave  |  del clave  |  keys  |  state  |  help' : 'set key value  |  get key  |  del key  |  keys  |  state  |  help'} />
      </div>
    </div>

  <!-- Cluster Admin Shell -->
    <div class="bg-black border border-red-900/50 rounded-xl overflow-hidden font-mono" id="admin-terminal">
      <!-- Terminal header -->
      <div class="flex items-center gap-2 px-4 py-2.5 bg-slate-900 border-b border-red-900/40">
        <span class="w-3 h-3 rounded-full bg-red-500 opacity-80"></span>
        <span class="w-3 h-3 rounded-full bg-amber-500 opacity-80"></span>
        <span class="w-3 h-3 rounded-full bg-green-500 opacity-50"></span>
        <span class="text-red-400/80 text-xs ml-3">cluster-admin — {isEs ? 'usar con precaución' : 'use with caution'}</span>
        <span class="ml-auto text-slate-600 text-xs">{isEs ? 'escribe' : 'type'} <span class="text-slate-400">help</span> {isEs ? 'para comandos' : 'for commands'}</span>
      </div>
      <!-- Output area -->
      <div id="admin-output" class="h-56 overflow-y-auto px-4 py-3 space-y-0.5 text-sm leading-5" style="scrollbar-color:#334155 #000"></div>
      <!-- Input line -->
      <div class="flex items-center gap-2 px-4 py-2.5 border-t border-red-900/30">
        <span class="text-red-400 select-none font-bold">#</span>
        <input id="admin-input" type="text" autocomplete="off" spellcheck="false"
          class="flex-1 bg-transparent text-amber-200 text-sm outline-none placeholder-slate-600 caret-red-400"
          placeholder={isEs ? 'kill N3  |  revive N3  |  partition N1,N2  |  heal  |  status' : 'kill N3  |  revive N3  |  partition N1,N2  |  heal  |  status'} />
      </div>
    </div>

    </div><!-- end terminals grid -->
  </section>

</Base>

<script define:vars={{ strings }}>
  window.__vizStrings = strings;
</script>
<script>
  import { waapi } from 'animejs';
  const strings = (window as any).__vizStrings;

  // ─── Constants ────────────────────────────────────────────────────────────────

  const COLOR = {
    follower:  '#6366f1',
    candidate: '#10b981',
    leader:    '#f59e0b',
    dead:      '#374151',
    learner:   '#22d3ee',
  };
  const FILL_ALPHA = {
    follower:  '#6366f118',
    candidate: '#10b98118',
    leader:    '#f59e0b22',
    dead:      '#37415108',
    learner:   '#22d3ee18',
  };

  const PACKET_LABEL = {
    request_vote:    'RV',
    vote_granted:    '✓',
    vote_denied:     '✗',
    heartbeat:       '♥',
    append_entries:  'AE',
    append_ack:      '✓',
  };
  const PACKET_COLOR = {
    request_vote:    '#10b981',
    vote_granted:    '#06b6d4',
    vote_denied:     '#ef4444',
    heartbeat:       '#f59e0b',
    append_entries:  '#f59e0b',
    append_ack:      '#38bdf8',
  };

  const NODE_R = 30;
  const TIMER_R = NODE_R + 12;
  const SVG_W = 800;
  const SVG_H = 460;

  const ET_MIN = 1500;
  const ET_MAX = 3000;
  const HB_INTERVAL = 600;
  const COMPACT_THRESHOLD = 8; // auto-compact when log exceeds this many entries

  const EVENT_LABELS = {
    election_timeout: 'election timeout',
    request_vote: 'RequestVote',
    vote_granted: 'vote granted',
    vote_denied: 'vote denied',
    leader_elected: 'leader elected',
    heartbeat: 'heartbeat',
    client_request: 'client request',
    append_entries: 'AppendEntries',
    append_ack: 'append ACK',
    entry_committed: 'entry committed',
    leader_crash: 'leader crash',
    node_recover: 'node recover',
    split_vote: 'split vote',
  };

  const EVENT_COLORS = {
    election_timeout: 'text-amber-300 bg-amber-900/30 border-amber-700/40',
    request_vote: 'text-emerald-300 bg-emerald-900/30 border-emerald-700/40',
    vote_granted: 'text-emerald-300 bg-emerald-900/30 border-emerald-700/40',
    vote_denied: 'text-red-300 bg-red-900/30 border-red-700/40',
    leader_elected: 'text-amber-300 bg-amber-900/30 border-amber-700/40',
    heartbeat: 'text-sky-300 bg-sky-900/30 border-sky-700/40',
    client_request: 'text-purple-300 bg-purple-900/30 border-purple-700/40',
    append_entries: 'text-sky-300 bg-sky-900/30 border-sky-700/40',
    append_ack: 'text-slate-300 bg-slate-800/50 border-slate-700/40',
    entry_committed: 'text-green-300 bg-green-900/30 border-green-700/40',
    leader_crash: 'text-red-300 bg-red-900/30 border-red-700/40',
    node_recover: 'text-indigo-300 bg-indigo-900/30 border-indigo-700/40',
    split_vote: 'text-amber-300 bg-amber-900/30 border-amber-700/40',
  };

  // ─── Live cluster types ────────────────────────────────────────────────────────

  let liveCluster = { nodes: [], term: 0 };
  let speedMultiplier = 0.5;
  let selectedNode = null;
  let nodeCount = 5;
  let simRunning = false;
  let heartbeatInterval = null;
  let logCounter = 0;

  const isolatedNodes = new Set();
  const timerAnimations = new Map();

  // ─── DOM refs ─────────────────────────────────────────────────────────────────

  const svgEl = document.getElementById('viz-svg');
  const edgesG   = document.getElementById('viz-edges');
  const clientG  = document.getElementById('viz-client');
  const nodesG   = document.getElementById('viz-nodes');
  const packetsG = document.getElementById('viz-packets');

  // ─── Permanent client node ────────────────────────────────────────────────────
  const CLIENT_X = 68;
  const CLIENT_Y = SVG_H - 52;
  const CLIENT_COLOR = '#a855f7';

  (() => {
    const ring = svgMake('circle', {
      cx: CLIENT_X, cy: CLIENT_Y, r: 22,
      fill: '#a855f708', stroke: CLIENT_COLOR,
      'stroke-width': 1.5, 'stroke-dasharray': '4 3', opacity: 0.7,
    });
    const dot = svgMake('circle', {
      cx: CLIENT_X, cy: CLIENT_Y, r: 14,
      fill: '#581c87', stroke: CLIENT_COLOR, 'stroke-width': 1.5,
    });
    const lbl = svgMake('text', {
      x: CLIENT_X, y: CLIENT_Y + 1,
      'text-anchor': 'middle', 'dominant-baseline': 'middle',
      fill: '#d8b4fe', 'font-size': 9,
      'font-family': 'JetBrains Mono, monospace', 'font-weight': 'bold',
      'pointer-events': 'none',
    });
    lbl.textContent = 'client';
    clientG.append(ring, dot, lbl);
  })();

  const tooltipG = document.getElementById('viz-tooltip');
  const tooltipBg = document.getElementById('viz-tooltip-bg');
  const tooltipText = document.getElementById('viz-tooltip-text');
  const narrationText = document.getElementById('narration-text');
  const narrationBadge = document.getElementById('narration-badge');
  const narrationType = document.getElementById('narration-type');
  const nodeDetail = document.getElementById('node-detail');
  const eventLog = document.getElementById('event-log');
  const btnReset = document.getElementById('btn-reset');
  const btnAddNode = document.getElementById('btn-add-node');
  const btnRemoveNode = document.getElementById('btn-remove-node');
  const nodeCountLabel = document.getElementById('node-count-label');
  const selSpeed = document.getElementById('sel-speed');
  const simStatusDot = document.getElementById('sim-status-dot');
  const simStatusText = document.getElementById('sim-status-text');

  // ─── SVG helpers ──────────────────────────────────────────────────────────────

  function svgMake(tag, attrs = {}) {
    const el = document.createElementNS('http://www.w3.org/2000/svg', tag);
    for (const [k, v] of Object.entries(attrs)) el.setAttribute(k, String(v));
    return el;
  }

  function nodePositions(n) {
    const cx = SVG_W / 2;
    const cy = SVG_H / 2;
    const r = Math.min(cx, cy) - NODE_R - 30;
    return Array.from({ length: n }, (_, i) => {
      const angle = (2 * Math.PI * i) / n - Math.PI / 2;
      return { x: cx + r * Math.cos(angle), y: cy + r * Math.sin(angle) };
    });
  }

  // ─── Election Timer Arcs ──────────────────────────────────────────────────────

  const timerCircumference = 2 * Math.PI * TIMER_R;

  function startTimerArc(nodeId, timeoutMs) {
    stopTimerArc(nodeId);
    const arc = document.getElementById(`vtimer-${nodeId}`);
    if (!arc) return;
    arc.style.strokeDashoffset = '0';
    arc.style.opacity = '1';
    const durationMs = Math.round(timeoutMs / speedMultiplier);
    const anim = waapi.animate(arc, {
      strokeDashoffset: [0, timerCircumference],
      duration: durationMs,
      ease: 'linear',
      loop: true,
    });
    timerAnimations.set(nodeId, anim);
  }

  function stopTimerArc(nodeId) {
    const existing = timerAnimations.get(nodeId);
    if (existing) {
      try { existing.pause?.(); } catch {}
      timerAnimations.delete(nodeId);
    }
    const arc = document.getElementById(`vtimer-${nodeId}`);
    if (arc) {
      arc.style.opacity = '0';
      arc.style.strokeDashoffset = '0';
    }
  }

  // ─── Rendering ────────────────────────────────────────────────────────────────

  function getLiveState() {
    return { nodes: liveCluster.nodes, term: liveCluster.term };
  }

  function renderCluster() {
    const state = getLiveState();
    const positions = nodePositions(state.nodes.length);
    // Map node.id → position (works even when IDs have gaps after removal)
    const posMap = new Map(state.nodes.map((n, i) => [n.id, positions[i]]));

    edgesG.innerHTML = '';
    const alive = state.nodes.filter(n => n.state !== 'dead');
    for (let i = 0; i < alive.length; i++) {
      for (let j = i + 1; j < alive.length; j++) {
        const a = posMap.get(alive[i].id);
        const b = posMap.get(alive[j].id);
        edgesG.appendChild(svgMake('line', {
          x1: a.x, y1: a.y, x2: b.x, y2: b.y,
          stroke: '#1e293b', 'stroke-width': 1.5,
        }));
      }
    }

    nodesG.innerHTML = '';
    state.nodes.forEach((node) => {
      const pos = posMap.get(node.id)!;
      const g = svgMake('g', { id: `vnode-${node.id}`, style: 'cursor:pointer' });

      const timerArc = svgMake('circle', {
        cx: pos.x, cy: pos.y, r: TIMER_R,
        fill: 'none', stroke: '#6366f1', 'stroke-width': 3,
        'stroke-dasharray': timerCircumference,
        'stroke-dashoffset': 0, 'stroke-linecap': 'round',
        opacity: node.state === 'follower' || node.state === 'candidate' ? 1 : 0,
        transform: `rotate(-90, ${pos.x}, ${pos.y})`,
        id: `vtimer-${node.id}`, style: 'pointer-events:none',
      });

      const glowR = svgMake('circle', {
        cx: pos.x, cy: pos.y, r: NODE_R + 10,
        fill: 'none',
        stroke: node.state === 'leader' ? COLOR.leader : 'transparent',
        'stroke-width': 2,
        opacity: node.state === 'leader' ? 0.5 : 0,
        id: `vglow-${node.id}`, style: 'pointer-events:none',
      });

      const circle = svgMake('circle', {
        cx: pos.x, cy: pos.y, r: NODE_R,
        fill: FILL_ALPHA[node.state] ?? FILL_ALPHA.dead,
        stroke: selectedNode === node.id ? '#38bdf8' : (COLOR[node.state] ?? COLOR.dead),
        'stroke-width': selectedNode === node.id ? 3 : 2,
        id: `vcircle-${node.id}`,
      });

      const labelId = svgMake('text', {
        x: pos.x, y: pos.y - 6,
        'text-anchor': 'middle', fill: COLOR[node.state] ?? COLOR.dead,
        'font-size': 12, 'font-family': 'JetBrains Mono, monospace',
        'font-weight': 'bold', style: 'pointer-events:none',
      });
      labelId.textContent = `N${node.id}`;

      const labelState = svgMake('text', {
        x: pos.x, y: pos.y + 10,
        'text-anchor': 'middle', fill: '#64748b',
        'font-size': 9, 'font-family': 'JetBrains Mono, monospace',
        style: 'pointer-events:none',
      });
      labelState.textContent = node.state;

      const labelTerm = svgMake('text', {
        x: pos.x, y: pos.y + 22,
        'text-anchor': 'middle', fill: '#475569',
        'font-size': 8, 'font-family': 'JetBrains Mono, monospace',
        style: 'pointer-events:none',
      });
      labelTerm.textContent = `t${node.term}`;

      g.appendChild(timerArc);
      g.appendChild(glowR);
      g.appendChild(circle);
      g.appendChild(labelId);
      g.appendChild(labelState);
      g.appendChild(labelTerm);

      if (node.state === 'learner') {
        const syncR = NODE_R + 8;
        const syncCirc = 2 * Math.PI * syncR;
        const pct = node.syncProgress ?? 0;
        const syncArc = svgMake('circle', {
          cx: pos.x, cy: pos.y, r: syncR,
          fill: 'none', stroke: '#22d3ee', 'stroke-width': 3,
          'stroke-dasharray': `${syncCirc * pct} ${syncCirc * (1 - pct)}`,
          'stroke-dashoffset': syncCirc * 0.25,
          'stroke-linecap': 'round', opacity: 0.8,
          style: 'pointer-events:none; transform-origin: center; transform: rotate(-90deg)',
        });
        const syncLbl = svgMake('text', {
          x: pos.x, y: pos.y + 22,
          'text-anchor': 'middle', fill: '#22d3ee',
          'font-size': 8, 'font-family': 'JetBrains Mono, monospace',
          style: 'pointer-events:none',
        });
        syncLbl.textContent = `${Math.round(pct * 100)}%`;
        g.appendChild(syncArc);
        g.appendChild(syncLbl);
      }

      nodesG.appendChild(g);

      g.addEventListener('mouseenter', () => {
        const stateColor =
          node.state === 'leader' ? '#f59e0b' :
          node.state === 'candidate' ? '#10b981' :
          node.state === 'dead' ? '#6b7280' : '#6366f1';

        tooltipText.innerHTML = '';
        const line1 = svgMake('tspan', { x: pos.x, dy: 0, fill: stateColor, 'font-weight': 'bold' });
        line1.textContent = `N${node.id} · ${node.state}`;
        const line2 = svgMake('tspan', { x: pos.x, dy: 17, fill: '#94a3b8' });
        line2.textContent = `term ${node.term}`;
        tooltipText.appendChild(line1);
        tooltipText.appendChild(line2);

        const PAD_X = 12, PAD_Y = 8, LINE_H = 17;
        const textW = Math.max(
          `N${node.id} · ${node.state}`.length,
          `term ${node.term}`.length
        ) * 7;
        const tipW = textW + PAD_X * 2;
        const tipH = LINE_H + 11 + PAD_Y * 2;
        const tipX = Math.min(Math.max(pos.x, tipW / 2 + 4), SVG_W - tipW / 2 - 4);
        const above = pos.y - NODE_R - tipH - 6;
        const tipY = above >= 4 ? above : pos.y + NODE_R + 6;

        tooltipText.setAttribute('x', String(tipX));
        tooltipText.setAttribute('y', String(tipY + PAD_Y + 11));
        tooltipBg.setAttribute('x', String(tipX - tipW / 2));
        tooltipBg.setAttribute('y', String(tipY));
        tooltipBg.setAttribute('width', String(tipW));
        tooltipBg.setAttribute('height', String(tipH));
        tooltipG.style.display = '';
      });

      g.addEventListener('mouseleave', () => { tooltipG.style.display = 'none'; });

      g.addEventListener('click', () => {
        selectedNode = selectedNode === node.id ? null : node.id;
        renderCluster();
        renderNodeDetail(node);
      });

      if (node.state === 'leader') {
        waapi.animate(glowR, {
          opacity: [0.5, 0.15, 0.5],
          r: [NODE_R + 10, NODE_R + 16, NODE_R + 10],
          duration: 1800, loop: true, ease: 'inOut(2)',
        });
      }
    });

    for (const node of state.nodes) {
      if (node.state === 'follower' || node.state === 'candidate') {
        if (!timerAnimations.has(node.id)) {
          startTimerArc(node.id, node.electionTimeout);
        }
      } else {
        stopTimerArc(node.id);
      }
    }

    for (const node of state.nodes) {
      const oldRing = document.getElementById(`vpartition-${node.id}`);
      if (oldRing) oldRing.remove();
      if (isolatedNodes.has(node.id)) {
        const pos = posMap.get(node.id);
        if (!pos) continue;
        const ring = svgMake('circle', {
          cx: pos.x, cy: pos.y, r: NODE_R + 18,
          fill: 'none', stroke: '#ef4444',
          'stroke-width': 2, 'stroke-dasharray': '6 4',
          opacity: 0.8, id: `vpartition-${node.id}`,
          style: 'pointer-events:none',
        });
        nodesG.appendChild(ring);
        const dimCircle = document.getElementById(`vcircle-${node.id}`);
        if (dimCircle) dimCircle.setAttribute('opacity', '0.35');
      } else {
        const dimCircle = document.getElementById(`vcircle-${node.id}`);
        if (dimCircle) dimCircle.setAttribute('opacity', '1');
      }
    }
  }

  // ─── Packet animations ────────────────────────────────────────────────────────

  function animatePacket(fromId, toId, color, label) {
    const positions = nodePositions(liveCluster.nodes.length);
    const posMap = new Map(liveCluster.nodes.map((n, i) => [n.id, positions[i]]));
    const from = posMap.get(fromId);
    const to = posMap.get(toId);
    if (!from || !to) return;

    const duration = Math.round(500 / speedMultiplier);

    const packet = svgMake('circle', { cx: from.x, cy: from.y, r: 7, fill: color, opacity: 0.95 });
    const trail1 = svgMake('circle', { cx: from.x, cy: from.y, r: 5, fill: color, opacity: 0.5 });
    const trail2 = svgMake('circle', { cx: from.x, cy: from.y, r: 3, fill: color, opacity: 0.2 });
    const pLabel = svgMake('text', {
      x: from.x, y: from.y - 12,
      'text-anchor': 'middle', fill: '#fff', 'font-size': 8,
      'font-family': 'JetBrains Mono, monospace', 'font-weight': 'bold',
      'pointer-events': 'none',
    });
    pLabel.textContent = label;

    packetsG.appendChild(trail2);
    packetsG.appendChild(trail1);
    packetsG.appendChild(packet);
    packetsG.appendChild(pLabel);

    waapi.animate(packet, { cx: to.x, cy: to.y, duration, ease: 'inOut(2)', onComplete: () => { packet.remove(); pLabel.remove(); } });
    waapi.animate(trail1, { cx: to.x, cy: to.y, opacity: [0.5, 0], duration, delay: 60, ease: 'inOut(2)', onComplete: () => trail1.remove() });
    waapi.animate(trail2, { cx: to.x, cy: to.y, opacity: [0.2, 0], duration, delay: 120, ease: 'inOut(2)', onComplete: () => trail2.remove() });
    waapi.animate(pLabel, { x: to.x, y: to.y - 12, opacity: [1, 0], duration, ease: 'inOut(2)' });
  }

  function flashNode(nodeId) {
    const circle = document.getElementById(`vcircle-${nodeId}`);
    if (!circle) return;
    waapi.animate(circle, { scale: [1, 1.2, 1], duration: 350, ease: 'out(3)' });
  }

  function flashNodeColor(nodeId, color) {
    const circle = document.getElementById(`vcircle-${nodeId}`);
    if (!circle) return;
    const origStroke = circle.getAttribute('stroke') ?? '#6366f1';
    const origFill = circle.getAttribute('fill') ?? '#6366f118';
    waapi.animate(circle, {
      stroke: [color, origStroke], fill: [color + '44', origFill],
      scale: [1, 1.3, 1], duration: 500, ease: 'out(3)',
    });
  }

  // ─── Narration + Event Log ────────────────────────────────────────────────────

  function setNarration(type, text) {
    narrationText.textContent = text;
    narrationBadge.classList.remove('hidden');
    narrationType.textContent = EVENT_LABELS[type] ?? type;
    narrationType.className = `px-2 py-0.5 rounded text-xs font-mono border ${EVENT_COLORS[type] ?? 'text-slate-300 bg-slate-800 border-slate-700'}`;
  }

  function addLogEntry(type, description) {
    logCounter++;
    const div = document.createElement('div');
    div.className = 'flex items-start gap-2 p-1.5 rounded-lg text-xs';
    div.innerHTML = `
      <span class="text-slate-600 font-mono shrink-0 mt-0.5">${String(logCounter).padStart(2, '0')}</span>
      <span class="px-1.5 py-0.5 rounded border text-xs font-mono shrink-0 ${EVENT_COLORS[type] ?? 'text-slate-400 bg-slate-800 border-slate-700'}">${EVENT_LABELS[type] ?? type}</span>
      <span class="text-slate-400 leading-tight">${description}</span>
    `;
    eventLog.appendChild(div);
    while (eventLog.children.length > 100) eventLog.removeChild(eventLog.firstChild);
    eventLog.scrollTop = eventLog.scrollHeight;
  }

  // ─── Live Simulation Engine ───────────────────────────────────────────────────

  function randInt(min, max) {
    return Math.floor(Math.random() * (max - min + 1)) + min;
  }

  function scheduleElectionTimer(node) {
    if (node.electionTimer) clearTimeout(node.electionTimer);
    node.electionTimer = setTimeout(() => onElectionTimeout(node.id), node.electionTimeout / speedMultiplier);
    startTimerArc(node.id, node.electionTimeout);
  }

  function resetElectionTimer(node) {
    node.electionTimeout = randInt(ET_MIN, ET_MAX);
    scheduleElectionTimer(node);
  }

  function stopNodeTimer(node) {
    if (node.electionTimer) { clearTimeout(node.electionTimer); node.electionTimer = null; }
    stopTimerArc(node.id);
  }

  function stopAllTimers() {
    for (const node of liveCluster.nodes) stopNodeTimer(node);
    if (heartbeatInterval) { clearInterval(heartbeatInterval); heartbeatInterval = null; }
  }

  function getLeader() {
    return liveCluster.nodes.find(n => n.state === 'leader') ?? null;
  }

  function reachablePeers(fromId) {
    if (isolatedNodes.has(fromId)) return [];
    return liveCluster.nodes.filter(n =>
      n.id !== fromId &&
      n.state !== 'dead' &&
      !isolatedNodes.has(n.id)
    );
  }

  function onElectionTimeout(nodeId) {
    if (!simRunning) return;
    const node = liveCluster.nodes.find(n => n.id === nodeId);
    if (!node || node.state === 'dead' || node.state === 'leader') return;

    liveCluster.term++;
    node.state = 'candidate';
    node.term = liveCluster.term;
    node.votedFor = node.id;
    node.votesReceived = 1;
    stopNodeTimer(node);

    setNarration('election_timeout', `N${node.id} ${strings.n_election_timeout}${node.term})`);
    addLogEntry('election_timeout', `N${node.id} → election (term ${node.term})`);
    flashNodeColor(node.id, '#10b981');
    renderCluster();

    const peers = reachablePeers(node.id);
    const majority = Math.floor(liveCluster.nodes.length / 2) + 1;

    if (peers.length === 0) {
      node.state = 'follower';
      node.votedFor = null;
      node.votesReceived = 0;
      resetElectionTimer(node);
      renderCluster();
      return;
    }

    setNarration('request_vote', `N${node.id} ${strings.n_request_vote}`);
    addLogEntry('request_vote', `N${node.id} → RequestVote to ${peers.map(p => `N${p.id}`).join(', ')}`);

    let grantedVotes = 1;
    let responsesPending = peers.length;

    for (const peer of peers) {
      const delay = randInt(50, 300) / speedMultiplier;
      animatePacket(node.id, peer.id, PACKET_COLOR.request_vote, PACKET_LABEL.request_vote);

      setTimeout(() => {
        if (!simRunning) return;
        const candidateNow = liveCluster.nodes.find(n => n.id === nodeId);
        if (!candidateNow || candidateNow.state !== 'candidate') return;

        const peerNow = liveCluster.nodes.find(n => n.id === peer.id);
        const granted =
          peerNow &&
          peerNow.state !== 'dead' &&
          !isolatedNodes.has(peer.id) &&
          (peerNow.votedFor === null || peerNow.votedFor === node.id) &&
          peerNow.term <= node.term;

        if (granted && peerNow) {
          peerNow.votedFor = node.id;
          peerNow.term = node.term;
          grantedVotes++;
          animatePacket(peer.id, nodeId, PACKET_COLOR.vote_granted, PACKET_LABEL.vote_granted);
          addLogEntry('vote_granted', `N${peer.id} ${strings.n_vote_granted} N${nodeId} (term ${node.term})`);
        } else {
          animatePacket(peer.id, nodeId, PACKET_COLOR.vote_denied, PACKET_LABEL.vote_denied);
          addLogEntry('vote_denied', `N${peer.id} ${strings.n_vote_denied} N${nodeId}`);
        }

        responsesPending--;

        if (grantedVotes >= majority && candidateNow.state === 'candidate') {
          becomeLeader(candidateNow, grantedVotes);
        } else if (responsesPending === 0 && candidateNow.state === 'candidate') {
          setNarration('split_vote', strings.n_split_vote);
          addLogEntry('split_vote', `N${nodeId} split vote — reverting to follower`);
          candidateNow.state = 'follower';
          candidateNow.votedFor = null;
          candidateNow.votesReceived = 0;
          resetElectionTimer(candidateNow);
          renderCluster();
        }
      }, delay);
    }
  }

  function becomeLeader(node, votes) {
    if (!simRunning) return;
    const total = liveCluster.nodes.length;

    node.state = 'leader';
    node.votesReceived = 0;

    for (const n of liveCluster.nodes) {
      if (n.id !== node.id && n.state !== 'dead') {
        n.state = 'follower';
        n.term = Math.max(n.term, node.term);
        n.votedFor = null;
        resetElectionTimer(n);
      }
    }
    stopNodeTimer(node);

    setNarration('leader_elected', `N${node.id} ${strings.n_leader_elected} ${votes}/${total} ${strings.n_leader_elected2}${node.term})`);
    addLogEntry('leader_elected', `N${node.id} is leader (term ${node.term})`);
    flashNodeColor(node.id, '#f59e0b');
    renderCluster();

    if (heartbeatInterval) clearInterval(heartbeatInterval);
    heartbeatInterval = setInterval(() => {
      sendHeartbeats(node.id);
    }, HB_INTERVAL / speedMultiplier);
  }

  function sendHeartbeats(leaderId) {
    if (!simRunning) return;
    const leader = liveCluster.nodes.find(n => n.id === leaderId);
    if (!leader || leader.state !== 'leader') {
      if (heartbeatInterval) { clearInterval(heartbeatInterval); heartbeatInterval = null; }
      return;
    }

    const followers = reachablePeers(leaderId);
    if (followers.length === 0) return;

    setNarration('heartbeat', `N${leaderId} ${strings.n_heartbeat}`);
    addLogEntry('heartbeat', `N${leaderId} → ♥ to ${followers.map(f => `N${f.id}`).join(', ')}`);

    for (const follower of followers) {
      animatePacket(leaderId, follower.id, PACKET_COLOR.heartbeat, PACKET_LABEL.heartbeat);
      const delay = randInt(30, 150) / speedMultiplier;
      setTimeout(() => {
        if (!simRunning) return;
        const f = liveCluster.nodes.find(n => n.id === follower.id);
        if (f && f.state === 'follower' && !isolatedNodes.has(f.id)) {
          resetElectionTimer(f);
        }
      }, delay);
    }
  }

  function initCluster(n) {
    liveCluster.nodes = Array.from({ length: n }, (_, i) => ({
      id: i + 1,
      state: 'follower',
      term: 0,
      votedFor: null,
      log: [],
      commitIndex: -1,
      snapshotIndex: -1,  // index of last entry included in snapshot (-1 = no snapshot)
      snapshotTerm: 0,
      electionTimer: null,
      electionTimeout: randInt(ET_MIN, ET_MAX),
      votesReceived: 0,
    }));
    liveCluster.term = 0;
  }

  // Compact a single node's log up to its commitIndex
  function compactNode(node) {
    if (node.commitIndex < 0) return false;
    const commitedEntries = node.log.slice(0, node.commitIndex + 1);
    if (commitedEntries.length === 0) return false;
    const lastEntry = commitedEntries[commitedEntries.length - 1];
    node.snapshotIndex = node.commitIndex;
    node.snapshotTerm = lastEntry.term;
    // Keep only entries after the snapshot
    node.log = node.log.slice(node.commitIndex + 1);
    node.commitIndex = -1; // reset — new entries will be relative to snapshot
    return true;
  }

  // Auto-compact all nodes that exceed the threshold
  function maybeAutoCompact() {
    let compacted = false;
    for (const node of liveCluster.nodes) {
      if (node.state !== 'dead' && node.log.length > COMPACT_THRESHOLD) {
        if (compactNode(node)) compacted = true;
      }
    }
    if (compacted) {
      renderCluster();
      if (selectedNode !== null) {
        const nd = liveCluster.nodes.find(n => n.id === selectedNode);
        if (nd) renderNodeDetail(nd);
      }
    }
  }

  function startSimulation() {
    stopAllTimers();
    simRunning = true;
    packetsG.innerHTML = '';
    logCounter = 0;
    eventLog.innerHTML = '';
    narrationBadge.classList.add('hidden');
    narrationText.textContent = strings.n_sim_started;
    nodeDetail.innerHTML = `<p class="text-slate-500 text-xs">${strings.d_node_detail_empty}</p>`;
    selectedNode = null;
    isolatedNodes.clear();

    for (const node of liveCluster.nodes) {
      scheduleElectionTimer(node);
    }
    renderCluster();

    simStatusDot.className = 'w-2 h-2 rounded-full bg-emerald-500 animate-pulse inline-block';
    simStatusText.textContent = strings.ui_live;
    simStatusText.className = 'text-emerald-400 text-xs font-mono';
  }

  function resetSimulation() {
    stopAllTimers();
    simRunning = false;
    initCluster(nodeCount);
    startSimulation();
  }

  // ─── Event listeners ──────────────────────────────────────────────────────────

  btnReset.addEventListener('click', resetSimulation);

  selSpeed.addEventListener('change', () => {
    speedMultiplier = parseFloat(selSpeed.value);
    for (const node of liveCluster.nodes) {
      if (node.state === 'follower' || node.state === 'candidate') {
        resetElectionTimer(node);
      }
    }
    const leader = getLeader();
    if (leader) {
      if (heartbeatInterval) clearInterval(heartbeatInterval);
      heartbeatInterval = setInterval(() => sendHeartbeats(leader.id), HB_INTERVAL / speedMultiplier);
    }
  });

  btnAddNode.addEventListener('click', () => {
    if (nodeCount >= 9) return;
    nodeCount++;
    nodeCountLabel.textContent = String(nodeCount);

    const currentTerm = liveCluster.nodes.reduce((max, n) => Math.max(max, n.term), 0);
    const leader = getLeader();

    const newNode = {
      id: nodeCount,
      state: 'learner',
      term: currentTerm,
      votedFor: null,
      log: [],
      commitIndex: -1,
      snapshotIndex: -1,
      snapshotTerm: 0,
      electionTimer: null,
      electionTimeout: randInt(ET_MIN, ET_MAX),
      votesReceived: 0,
      syncProgress: 0,
    };
    liveCluster.nodes.push(newNode);
    renderCluster();

    const stepDelay = Math.round(400 / speedMultiplier);
    const sourceId = leader ? leader.id : liveCluster.nodes.find(n => n.state !== 'dead' && n.id !== newNode.id)?.id;
    const leaderHasSnapshot = leader && leader.snapshotIndex >= 0;

    function promoteNewNode() {
      if (leader) {
        // Commit ADD_NODE membership change with AE animation
        const entry = { term: currentTerm, command: `ADD_NODE N${newNode.id}`, committed: false };
        liveCluster.nodes.forEach(n => { if (n.state !== 'dead') n.log.push({ ...entry }); });
        renderCluster();
        // Show AE packets from leader to peers for the membership change
        const peers = liveCluster.nodes.filter(n => n.id !== leader.id && n.state !== 'dead');
        peers.forEach((peer, i) => {
          const positions = nodePositions(liveCluster.nodes.length);
          const pm = new Map(liveCluster.nodes.map((n, j) => [n.id, positions[j]]));
          const src = pm.get(leader.id), dst = pm.get(peer.id);
          if (src && dst) kvSpawnPacket(src.x, src.y, dst.x, dst.y, '#f59e0b', 'AE', i * 50, undefined);
        });
        setTimeout(() => {
          liveCluster.nodes.forEach(n => {
            const e = n.log[n.log.length - 1];
            if (e && e.command === `ADD_NODE N${newNode.id}`) {
              e.committed = true;
              n.commitIndex = n.log.length - 1;
            }
          });
          newNode.state = 'follower';
          newNode.syncProgress = undefined;
          scheduleElectionTimer(newNode);
          setNarration('node_joined', `N${newNode.id} ${strings.n_node_joined_ok}${currentTerm})`);
          addLogEntry('node_recover', `N${newNode.id} promoted — voter (term ${currentTerm})`);
          renderCluster();
        }, stepDelay);
      } else {
        newNode.state = 'follower';
        newNode.syncProgress = undefined;
        scheduleElectionTimer(newNode);
        setNarration('node_joined', `N${newNode.id} ${strings.n_node_joined_wait}`);
        renderCluster();
      }
    }

    if (leaderHasSnapshot) {
      // Fast path: InstallSnapshot — single big packet, jump straight to 100%
      setNarration('node_joining', `N${newNode.id} ${strings.n_node_joining_snap}`);
      addLogEntry('append_entries', `N${leader.id} → InstallSnapshot → N${newNode.id}`);
      newNode.syncProgress = 0.1;
      renderCluster();
      const positions = nodePositions(liveCluster.nodes.length);
      const pm = new Map(liveCluster.nodes.map((n, i) => [n.id, positions[i]]));
      const srcPos = pm.get(leader.id), dstPos = pm.get(newNode.id);
      if (srcPos && dstPos) {
        // Large cyan packet representing the snapshot
        kvSpawnPacket(srcPos.x, srcPos.y, dstPos.x, dstPos.y, '#22d3ee', 'snap', 0, () => {
          // Apply snapshot to new node
          newNode.snapshotIndex = leader.snapshotIndex;
          newNode.snapshotTerm = leader.snapshotTerm;
          newNode.log = [...leader.log]; // copy post-snapshot entries
          newNode.commitIndex = leader.commitIndex;
          newNode.syncProgress = 1;
          setNarration('node_joining', `N${newNode.id} ${strings.n_install_snapshot}`);
          renderCluster();
          setTimeout(promoteNewNode, stepDelay);
        });
      } else {
        setTimeout(promoteNewNode, stepDelay * 3);
      }
    } else {
      // Slow path: AE catch-up steps
      setNarration('node_joining', `N${newNode.id} ${strings.n_node_joining}`);
      const CATCHUP_STEPS = 5;
      let step = 0;
      function catchupStep() {
        step++;
        newNode.syncProgress = step / CATCHUP_STEPS;
        if (sourceId) {
          const positions = nodePositions(liveCluster.nodes.length);
          const pm = new Map(liveCluster.nodes.map((n, i) => [n.id, positions[i]]));
          const srcPos = pm.get(sourceId), dstPos = pm.get(newNode.id);
          if (srcPos && dstPos) kvSpawnPacket(srcPos.x, srcPos.y, dstPos.x, dstPos.y, '#f59e0b', 'AE', 0, undefined);
        }
        renderCluster();
        if (step < CATCHUP_STEPS) {
          setTimeout(catchupStep, stepDelay);
        } else {
          setTimeout(promoteNewNode, stepDelay);
        }
      }
      setTimeout(catchupStep, stepDelay);
    }
  });

  btnRemoveNode.addEventListener('click', () => {
    if (nodeCount <= 3) return;
    const removedId = nodeCount;
    nodeCount--;
    nodeCountLabel.textContent = String(nodeCount);

    const node = liveCluster.nodes.find(n => n.id === removedId);
    if (node) {
      const wasLeader = node.state === 'leader';
      stopNodeTimer(node);
      if (wasLeader && heartbeatInterval) {
        clearInterval(heartbeatInterval);
        heartbeatInterval = null;
      }
      liveCluster.nodes = liveCluster.nodes.filter(n => n.id !== removedId);
      const msg = wasLeader ? `N${removedId} ${strings.n_node_removed_leader}` : `N${removedId} ${strings.n_node_removed}`;
      setNarration('node_left', msg);
    }
    renderCluster();
  });

