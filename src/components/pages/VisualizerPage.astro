  function kvCurrentLeader() {
    const state = getLiveState();
    const leader = state.nodes.find(n => n.state === 'leader');
    if (!leader) return null;
    return { id: leader.id, nodeCount: state.nodes.length };
  }

  function kvSpawnPacket(fromX, fromY, toX, toY, color, label, delay, onDone) {
    const dur = Math.round(500 / speedMultiplier);
    const pkt = svgMake('circle', { cx: fromX, cy: fromY, r: 7, fill: color, opacity: 0.95 });
    const t1  = svgMake('circle', { cx: fromX, cy: fromY, r: 5, fill: color, opacity: 0.5 });
    const t2  = svgMake('circle', { cx: fromX, cy: fromY, r: 3, fill: color, opacity: 0.22 });
    const lbl = svgMake('text', {
      x: fromX, y: fromY - 11, 'text-anchor': 'middle', fill: '#fff',
      'font-size': 8, 'font-family': 'JetBrains Mono, monospace',
      'font-weight': 'bold', 'pointer-events': 'none',
    });
    lbl.textContent = label;
    packetsG.append(t2, t1, pkt, lbl);

    const ease = 'inOut(2)';
    waapi.animate(pkt, { cx: toX, cy: toY, duration: dur, delay, ease, onComplete: () => { pkt.remove(); onDone?.(); } });
    waapi.animate(t1,  { cx: toX, cy: toY, duration: dur, delay: delay + 60, ease, onComplete: () => t1.remove() });
    waapi.animate(t2,  { cx: toX, cy: toY, duration: dur, delay: delay + 120, ease, onComplete: () => t2.remove() });
    waapi.animate(lbl, { x: toX, y: toY - 11, opacity: [1, 0], duration: dur, delay, ease, onComplete: () => lbl.remove() });
  }

  function kvAnimateWrite(leaderId, followerIds, onDone) {
    const state = getLiveState();
    const positions = nodePositions(state.nodes.length);
    const posMap = new Map(state.nodes.map((n, i) => [n.id, positions[i]]));
    const leaderPos = posMap.get(leaderId);
    if (!leaderPos) return;

    const ACK_COLOR = '#22d3ee';

    kvSpawnPacket(CLIENT_X, CLIENT_Y, leaderPos.x, leaderPos.y, CLIENT_COLOR, 'write', 0, () => {
      flashNode(leaderId);
      let completed = 0;
      followerIds.forEach((fid, i) => {
        const fPos = posMap.get(fid);
        if (!fPos) return;
        kvSpawnPacket(leaderPos.x, leaderPos.y, fPos.x, fPos.y, '#f59e0b', 'AE', i * 60, () => {
          flashNode(fid);
          kvSpawnPacket(fPos.x, fPos.y, leaderPos.x, leaderPos.y, ACK_COLOR, '✓', 0, () => {
            completed++;
            if (completed === followerIds.length) {
              kvSpawnPacket(leaderPos.x, leaderPos.y, CLIENT_X, CLIENT_Y, '#4ade80', 'ok', 0, onDone);
              flashNode(leaderId);
            }
          });
        });
      });
      if (followerIds.length === 0) {
        kvSpawnPacket(leaderPos.x, leaderPos.y, CLIENT_X, CLIENT_Y, '#4ade80', 'ok', 0, onDone);
      }
    });

    const clientNodeDot = clientG.querySelector('circle:nth-child(2)');
    if (clientNodeDot) {
      waapi.animate(clientNodeDot, { r: [14, 18, 14], opacity: [1, 0.6, 1], duration: 600, loop: 2 });
    }
  }

  function kvAnimateRead(leaderId, onDone) {
    const state = getLiveState();
    const positions = nodePositions(state.nodes.length);
    const posMap = new Map(state.nodes.map((n, i) => [n.id, positions[i]]));
    const leaderPos = posMap.get(leaderId);
    if (!leaderPos) { onDone?.(); return; }

    // client → leader (read request), then leader → client (value response)
    kvSpawnPacket(CLIENT_X, CLIENT_Y, leaderPos.x, leaderPos.y, '#38bdf8', 'read', 0, () => {
      flashNode(leaderId);
      kvSpawnPacket(leaderPos.x, leaderPos.y, CLIENT_X, CLIENT_Y, '#4ade80', 'val', 0, onDone);
    });
  }

  async function kvExecWrite(op, key, value) {
    const leader = kvCurrentLeader();
    if (!leader) { kvPrint(strings.kv_no_leader, 'text-red-400'); return; }

    if (op === 'DEL' && !kvStore.has(key)) { kvPrint(`${strings.kv_key_not_found}${key}`, 'text-amber-400'); return; }

    const command = op === 'SET' ? `SET ${key}=${value}` : `DEL ${key}`;
    kvPrint(`${strings.kv_leader_recv} N${leader.id}${strings.kv_received}${op} ${op === 'SET' ? `${key} = ${value}` : key}`, 'text-sky-300');

    const state = getLiveState();
    const leaderNode = state.nodes.find(n => n.id === leader.id);
    const newEntry = { term: leaderNode.term, command, committed: false };
    state.nodes.forEach(n => { if (n.state !== 'dead') n.log.push({ ...newEntry }); });
    renderCluster();

    const followers = state.nodes.filter(n => n.state === 'follower' && !isolatedNodes.has(n.id)).map(n => n.id);
    const majority = Math.floor(state.nodes.length / 2) + 1;

    await new Promise(resolve => { kvAnimateWrite(leader.id, followers, resolve); });

    kvPrint(`${strings.kv_replicating}${followers.map(id => `N${id}`).join(', ')}...`, 'text-sky-300');
    await new Promise(r => setTimeout(r, 120));
    kvPrint(`${strings.kv_majority_ack}${majority}/${state.nodes.length})`, 'text-sky-300');
    await new Promise(r => setTimeout(r, 80));

    state.nodes.forEach(n => {
      if (n.state !== 'dead') {
        const entry = n.log[n.log.length - 1];
        if (entry && !entry.committed && entry.command === command) {
          entry.committed = true;
          n.commitIndex = n.log.length - 1;
        }
      }
    });

    if (op === 'SET') {
      kvStore.set(key, value);
      kvPrint(`${strings.kv_committed_set}${key} = ${value}`, 'text-green-400');
    } else {
      kvStore.delete(key);
      kvPrint(`${strings.kv_committed_del}${key}`, 'text-green-400');
    }

    renderCluster();
    if (selectedNode !== null) {
      const nd = state.nodes.find(n => n.id === selectedNode);
      if (nd) renderNodeDetail(nd);
    }
    maybeAutoCompact();
  }

  async function kvHandleCommand(raw) {
    const trimmed = raw.trim();
    if (!trimmed) return;
    kvPrint(`$ ${trimmed}`, 'text-green-300');
    const parts = trimmed.split(/\s+/);
    const cmd = parts[0].toLowerCase();

    if (cmd === 'clear') { kvOutput.innerHTML = ''; return; }

    if (cmd === 'help') {
      kvPrint(strings.kv_help_header, 'text-slate-400');
      kvPrint(strings.kv_help_set,    'text-slate-400');
      kvPrint(strings.kv_help_get,    'text-slate-400');
      kvPrint(strings.kv_help_del,    'text-slate-400');
      kvPrint(strings.kv_help_keys,   'text-slate-400');
      kvPrint(strings.kv_help_state,  'text-slate-400');
      kvPrint(strings.kv_help_clear,  'text-slate-400');
      kvPrint(strings.kv_help_help,   'text-slate-400');
      return;
    }

    if (cmd === 'keys') {
      if (kvStore.size === 0) { kvPrint(strings.kv_empty_store, 'text-slate-500'); }
      else { for (const [k, v] of kvStore) kvPrint(`  ${k} = ${v}`, 'text-slate-300'); }
      return;
    }

    if (cmd === 'state') {
      const state = getLiveState();
      kvPrint(`${strings.kv_cluster_term}${state.term}`, 'text-slate-300');
      for (const n of state.nodes) {
        const role = n.state === 'leader' ? strings.kv_role_leader : n.state === 'dead' ? strings.kv_role_dead : '';
        kvPrint(`  N${n.id}: ${n.state}${role}  term=${n.term}  log=${n.log.length}  commit=${n.commitIndex}`, 'text-slate-300');
      }
      return;
    }

    if (cmd === 'get') {
      const key = parts[1];
      if (!key) { kvPrint(strings.kv_usage_get, 'text-amber-400'); return; }
      const leader = kvCurrentLeader();
      if (!leader) { kvPrint(strings.kv_no_leader, 'text-red-400'); return; }
      kvPrint(`${strings.kv_reading_from} N${leader.id}`, 'text-sky-300');
      await new Promise<void>(resolve => kvAnimateRead(leader.id, resolve));
      if (kvStore.has(key)) kvPrint(`  ${key} = ${kvStore.get(key)}`, 'text-green-300');
      else kvPrint(`${strings.kv_key_not_found}${key}`, 'text-amber-400');
      return;
    }

    if (cmd === 'set') {
      const key = parts[1];
      const value = parts.slice(2).join(' ');
      if (!key || !value) { kvPrint(strings.kv_usage_set, 'text-amber-400'); return; }
      await kvExecWrite('SET', key, value);
      return;
    }

    if (cmd === 'del') {
      const key = parts[1];
      if (!key) { kvPrint(strings.kv_usage_del, 'text-amber-400'); return; }
      await kvExecWrite('DEL', key);
      return;
    }

    kvPrint(`${strings.kv_unknown_cmd}${cmd}  (type help)`, 'text-red-400');
  }

  kvPrint(strings.kv_welcome1, 'text-slate-500');
  kvPrint(strings.kv_welcome2, 'text-slate-500');
  kvPrint(strings.kv_welcome3, 'text-slate-600');
  kvTerminal.addEventListener('click', () => kvInput.focus());
  function makeHistory(input: HTMLInputElement, handler: (cmd: string) => Promise<void>) {
    const history: string[] = [];
    let cursor = -1;
    let draft = '';

    input.addEventListener('keydown', async (e) => {
      if (e.key === 'ArrowUp') {
        e.preventDefault();
        if (history.length === 0) return;
        if (cursor === -1) draft = input.value;
        cursor = Math.min(cursor + 1, history.length - 1);
        input.value = history[cursor];
        setTimeout(() => input.setSelectionRange(input.value.length, input.value.length), 0);
      } else if (e.key === 'ArrowDown') {
        e.preventDefault();
        if (cursor === -1) return;
        cursor--;
        input.value = cursor === -1 ? draft : history[cursor];
        setTimeout(() => input.setSelectionRange(input.value.length, input.value.length), 0);
      } else if (e.key === 'Enter') {
        const val = input.value.trim();
        input.value = '';
        cursor = -1;
        draft = '';
        if (val) history.unshift(val);
        await handler(val);
      }
    });
  }

  makeHistory(kvInput, kvHandleCommand);

  // ─── Cluster Admin Shell ──────────────────────────────────────────────────────

  const adminOutput = document.getElementById('admin-output');
  const adminInput  = document.getElementById('admin-input');
  const adminTerminal = document.getElementById('admin-terminal');
  const ADMIN_MAX_SCROLLBACK = 80;

  function adminPrint(line, cls = 'text-amber-100/80') {
    const div = document.createElement('div');
    div.className = `font-mono text-sm whitespace-pre ${cls}`;
    div.textContent = line;
    adminOutput.appendChild(div);
    while (adminOutput.children.length > ADMIN_MAX_SCROLLBACK) adminOutput.removeChild(adminOutput.firstChild);
    adminOutput.scrollTop = adminOutput.scrollHeight;
  }

  function adminParseNodeId(raw) {
    const m = raw.trim().toUpperCase().match(/^N?(\d+)$/);
    if (!m) return null;
    return parseInt(m[1], 10);
  }

  async function adminHandleCommand(raw) {
    const trimmed = raw.trim();
    if (!trimmed) return;
    adminPrint(`# ${trimmed}`, 'text-red-300');
    const parts = trimmed.split(/[\s,]+/).filter(Boolean);
    const cmd = parts[0].toLowerCase();

    if (cmd === 'clear') { adminOutput.innerHTML = ''; return; }

    if (cmd === 'help') {
      adminPrint(strings.adm_help_header,  'text-slate-400');
      adminPrint(strings.adm_help_kill,    'text-slate-400');
      adminPrint(strings.adm_help_revive,  'text-slate-400');
      adminPrint(strings.adm_help_part,    'text-slate-400');
      adminPrint(strings.adm_help_heal,    'text-slate-400');
      adminPrint(strings.adm_help_quorum,  'text-slate-400');
      adminPrint(strings.adm_help_leader,  'text-slate-400');
      adminPrint(strings.adm_help_term,    'text-slate-400');
      adminPrint(strings.adm_help_logs,    'text-slate-400');
      adminPrint(strings.adm_help_status,  'text-slate-400');
      adminPrint(strings.adm_help_compact, 'text-slate-400');
      adminPrint(strings.adm_help_clear,   'text-slate-400');
      adminPrint(strings.adm_help_help,    'text-slate-400');
      return;
    }

    const state = getLiveState();

    if (cmd === 'kill') {
      const id = adminParseNodeId(parts[1] ?? '');
      if (!id) { adminPrint(strings.adm_usage_kill, 'text-amber-400'); return; }
      const node = state.nodes.find(n => n.id === id);
      if (!node) { adminPrint(`  N${id}${strings.adm_not_found}`, 'text-red-400'); return; }
      if (node.state === 'dead') { adminPrint(`  N${id}${strings.adm_already_dead}`, 'text-amber-400'); return; }
      const wasLeader = node.state === 'leader';
      flashNodeColor(id, '#ef4444');
      await new Promise(r => setTimeout(r, 300));
      node.state = 'dead';
      stopNodeTimer(node);
      if (wasLeader && heartbeatInterval) { clearInterval(heartbeatInterval); heartbeatInterval = null; }
      renderCluster();
      addLogEntry('leader_crash', wasLeader ? `N${id} (leader) crashed` : `N${id} crashed`);
      adminPrint(`  ✗ N${id}${strings.adm_is_dead}${wasLeader ? strings.adm_leader_lost : ''}`, 'text-red-400');

      const liveNodes = state.nodes.filter(n => n.state !== 'dead' && !isolatedNodes.has(n.id));
      const majority = Math.floor(state.nodes.length / 2) + 1;
      if (liveNodes.length < majority) {
        adminPrint(strings.adm_quorum_lost, 'text-red-400');
      } else {
        adminPrint(`${strings.adm_quorum_intact}${liveNodes.length}/${state.nodes.length}${strings.adm_alive_suffix}`, 'text-slate-400');
      }
      return;
    }

    if (cmd === 'revive') {
      const id = adminParseNodeId(parts[1] ?? '');
      if (!id) { adminPrint(strings.adm_usage_revive, 'text-amber-400'); return; }
      const node = state.nodes.find(n => n.id === id);
      if (!node) { adminPrint(`  N${id}${strings.adm_not_found}`, 'text-red-400'); return; }
      if (node.state !== 'dead') { adminPrint(`  N${id}${strings.adm_not_dead}${node.state})`, 'text-amber-400'); return; }
      const currentTerm = Math.max(...state.nodes.map(n => n.term));
      node.state = 'follower';
      node.term = currentTerm;
      node.votedFor = null;
      node.votesReceived = 0;
      node.electionTimeout = randInt(ET_MIN, ET_MAX);
      scheduleElectionTimer(node);
      renderCluster();
      flashNodeColor(id, '#22c55e');
      addLogEntry('node_recover', `N${id} revived as follower (term ${currentTerm})`);
      adminPrint(`${strings.adm_rejoined}N${id}${strings.adm_rejoined_as}${currentTerm})`, 'text-green-400');
      return;
    }

    if (cmd === 'partition') {
      const ids = parts.slice(1).map(p => adminParseNodeId(p)).filter(Boolean);
      if (ids.length === 0) { adminPrint(strings.adm_usage_part, 'text-amber-400'); return; }
      for (const id of ids) {
        if (!state.nodes.find(n => n.id === id)) { adminPrint(`  N${id}${strings.adm_skipped}`, 'text-amber-400'); continue; }
        isolatedNodes.add(id);
        adminPrint(`  N${id}${strings.adm_isolated}`, 'text-red-400');
        const positions = nodePositions(state.nodes.length);
        const posMap = new Map(state.nodes.map((n, i) => [n.id, positions[i]]));
        for (const other of state.nodes) {
          if (other.id === id || other.state === 'dead' || isolatedNodes.has(other.id)) continue;
          const fromPos = posMap.get(other.id);
          const toPos = posMap.get(id);
          if (!fromPos || !toPos) continue;
          const midX = (fromPos.x + toPos.x) / 2;
          const midY = (fromPos.y + toPos.y) / 2;
          const cross = svgMake('text', {
            x: midX, y: midY, 'text-anchor': 'middle', 'dominant-baseline': 'middle',
            fill: '#ef4444', 'font-size': 14, 'font-weight': 'bold',
            'font-family': 'JetBrains Mono, monospace', 'pointer-events': 'none', opacity: 1,
          });
          cross.textContent = '✗';
          packetsG.appendChild(cross);
          waapi.animate(cross, { opacity: [1, 0], duration: 900, delay: Math.random() * 200, ease: 'out(2)', onComplete: () => cross.remove() });
        }
      }
      renderCluster();
      return;
    }

    if (cmd === 'heal') {
      if (isolatedNodes.size === 0) { adminPrint(strings.adm_no_partitions, 'text-slate-500'); return; }
      const healed = [...isolatedNodes].map(id => `N${id}`).join(', ');
      isolatedNodes.clear();
      renderCluster();
      adminPrint(`${strings.adm_healed}${healed}`, 'text-green-400');
      return;
    }

    if (cmd === 'quorum') {
      const total = state.nodes.length;
      const alive = state.nodes.filter(n => n.state !== 'dead').length;
      const majority = Math.floor(total / 2) + 1;
      const hasQuorum = alive >= majority;
      adminPrint(`${strings.adm_total_nodes}${total}`, 'text-slate-300');
      adminPrint(`${strings.adm_alive}${alive}`, 'text-slate-300');
      adminPrint(`${strings.adm_majority}${majority}`, 'text-slate-300');
      adminPrint(`${strings.adm_quorum_label}${hasQuorum ? 'YES' : 'NO'}`, hasQuorum ? 'text-green-400' : 'text-red-400');
      return;
    }

    if (cmd === 'leader') {
      const leader = state.nodes.find(n => n.state === 'leader');
      if (!leader) { adminPrint(strings.adm_no_leader, 'text-red-400'); return; }
      adminPrint(`${strings.adm_leader_label}N${leader.id}  (term ${leader.term})`, 'text-amber-300');
      return;
    }

    if (cmd === 'term') {
      adminPrint(`${strings.adm_cluster_term}${state.term}`, 'text-slate-300');
      return;
    }

    if (cmd === 'logs') {
      adminPrint(strings.adm_logs_header, 'text-slate-500');
      adminPrint('  ──────────────────────────────', 'text-slate-700');
      for (const n of state.nodes) {
        const row = `  N${String(n.id).padEnd(4)} ${String(n.log.length).padEnd(5)}  ${String(n.commitIndex).padEnd(11)}  ${n.state}`;
        const cls = n.state === 'dead' ? 'text-slate-500' : n.state === 'leader' ? 'text-amber-300' : 'text-slate-300';
        adminPrint(row, cls);
      }
      return;
    }

    if (cmd === 'status') {
      const leader = state.nodes.find(n => n.state === 'leader');
      const total = state.nodes.length;
      const alive = state.nodes.filter(n => n.state !== 'dead').length;
      const majority = Math.floor(total / 2) + 1;
      const hasQuorum = alive >= majority;
      adminPrint(`${strings.adm_status_term}${state.term}`, 'text-slate-300');
      adminPrint(`${strings.adm_status_leader}${leader ? `N${leader.id} (term ${leader.term})` : strings.adm_status_none}`, leader ? 'text-amber-300' : 'text-red-400');
      adminPrint(`${strings.adm_status_quorum}${alive}/${total}${strings.adm_alive_s}${majority}${hasQuorum ? strings.adm_ok : strings.adm_lost}`, hasQuorum ? 'text-green-400' : 'text-red-400');
      if (isolatedNodes.size > 0) adminPrint(`${strings.adm_partitioned}${[...isolatedNodes].map(id => `N${id}`).join(', ')}`, 'text-red-400');
      adminPrint('  ──────────────────────────────', 'text-slate-700');
      for (const n of state.nodes) {
        const isolated = isolatedNodes.has(n.id) ? strings.adm_isolated_tag : '';
        const row = `  N${n.id}: ${n.state}${isolated}  term=${n.term}  log=${n.log.length}  commit=${n.commitIndex}`;
        const cls = n.state === 'dead' ? 'text-slate-500' : n.state === 'leader' ? 'text-amber-300' : isolatedNodes.has(n.id) ? 'text-red-300' : 'text-slate-300';
        adminPrint(row, cls);
      }
      return;
    }

    if (cmd === 'compact') {
      let anyCompacted = false;
      let maxSnapIdx = -1;
      for (const node of state.nodes) {
        if (node.state !== 'dead' && node.commitIndex >= 0) {
          if (compactNode(node)) { anyCompacted = true; maxSnapIdx = Math.max(maxSnapIdx, node.snapshotIndex); }
        }
      }
      if (anyCompacted) {
        setNarration('entry_committed', strings.n_compacting);
        renderCluster();
        adminPrint(`${strings.adm_compact_done}${maxSnapIdx}`, 'text-cyan-400');
        for (const node of state.nodes) {
          if (node.snapshotIndex >= 0) {
            adminPrint(`  N${node.id}: ${strings.adm_snap_label}${node.snapshotIndex}  log=${node.log.length}`, 'text-cyan-300');
          }
        }
      } else {
        adminPrint(strings.adm_compact_none, 'text-slate-500');
      }
      return;
    }

    adminPrint(`${strings.adm_unknown_cmd}${cmd}${strings.adm_type_help}`, 'text-red-400');
  }

  adminPrint(strings.adm_welcome1, 'text-slate-500');
  adminPrint(strings.adm_welcome2, 'text-amber-900/60');
  adminPrint(strings.adm_welcome3, 'text-slate-600');
  adminTerminal.addEventListener('click', () => adminInput.focus());
  makeHistory(adminInput, adminHandleCommand);

  // ─── Bootstrap ────────────────────────────────────────────────────────────────

  initCluster(nodeCount);
  startSimulation();
</script>
