const pythonCode = `# raft.py — Minimal Raft node (single-process simulation)
# Focuses on state transitions and the core data structures.
# Not production-ready — no real networking, no persistence.

import random
import time
from dataclasses import dataclass, field
from enum import Enum
from typing import Optional

class State(Enum):
    FOLLOWER  = "follower"
    CANDIDATE = "candidate"
    LEADER    = "leader"

@dataclass
class LogEntry:
    term: int       # which term this entry was created in
    command: str    # the actual command (e.g. "SET x=1")

@dataclass
class RaftNode:
    id: int
    peers: list["RaftNode"] = field(default_factory=list)

    # Persistent state (survive restarts)
    current_term: int = 0
    voted_for: Optional[int] = None  # candidate ID voted for this term
    log: list[LogEntry] = field(default_factory=list)

    # Volatile state
    state: State = State.FOLLOWER
    commit_index: int = -1  # highest log entry known to be committed
    last_applied: int = -1  # highest log entry applied to state machine

    # Leader-only state (reinitialized after election)
    next_index: dict[int, int] = field(default_factory=dict)
    match_index: dict[int, int] = field(default_factory=dict)

    # Simulated state machine
    kv_store: dict[str, str] = field(default_factory=dict)

    def become_candidate(self):
        """Timeout expired — start an election."""
        self.state = State.CANDIDATE
        self.current_term += 1
        self.voted_for = self.id  # vote for self
        print(f"[N{self.id}] → candidate (term {self.current_term})")

    def request_vote(self, candidate_id: int, candidate_term: int,
                     last_log_index: int, last_log_term: int) -> bool:
        """
        Decide whether to grant a vote.
        Two conditions must both hold:
          1. candidate's term >= our term
          2. candidate's log is at least as up-to-date as ours
        """
        if candidate_term < self.current_term:
            return False  # stale candidate

        # Update term if we see a higher one
        if candidate_term > self.current_term:
            self.current_term = candidate_term
            self.voted_for = None
            self.state = State.FOLLOWER

        already_voted = self.voted_for not in (None, candidate_id)
        if already_voted:
            return False

        # Log up-to-date check
        my_last_term  = self.log[-1].term if self.log else 0
        my_last_index = len(self.log) - 1
        log_ok = (candidate_term > my_last_term or
                  (candidate_term == my_last_term and last_log_index >= my_last_index))

        if log_ok:
            self.voted_for = candidate_id
            return True
        return False

    def append_entries(self, leader_term: int, leader_id: int,
                       prev_log_index: int, prev_log_term: int,
                       entries: list[LogEntry], leader_commit: int) -> bool:
        """
        Core RPC for both heartbeats (entries=[]) and log replication.
        Returns True if successful.
        """
        if leader_term < self.current_term:
            return False

        # Valid leader — reset to follower
        self.current_term = leader_term
        self.state = State.FOLLOWER
        self.voted_for = None

        # Consistency check: does our log match at prev_log_index?
        if prev_log_index >= 0:
            if len(self.log) <= prev_log_index:
                return False  # we're missing entries
            if self.log[prev_log_index].term != prev_log_term:
                # Conflict — delete from this point forward
                self.log = self.log[:prev_log_index]
                return False

        # Append new entries (skip duplicates)
        for i, entry in enumerate(entries):
            idx = prev_log_index + 1 + i
            if idx < len(self.log):
                if self.log[idx].term != entry.term:
                    self.log = self.log[:idx]  # delete conflicting suffix
                    self.log.append(entry)
            else:
                self.log.append(entry)

        # Update commit index and apply to state machine
        if leader_commit > self.commit_index:
            self.commit_index = min(leader_commit, len(self.log) - 1)
            self._apply_committed()

        return True

    def _apply_committed(self):
        """Apply log entries up to commit_index to the state machine."""
        while self.last_applied < self.commit_index:
            self.last_applied += 1
            cmd = self.log[self.last_applied].command
            self._execute(cmd)

    def _execute(self, command: str):
        """Toy state machine: parses SET/GET/DEL commands."""
        parts = command.split()
        if parts[0] == "SET" and "=" in parts[1]:
            k, v = parts[1].split("=", 1)
            self.kv_store[k] = v
        elif parts[0] == "DEL":
            self.kv_store.pop(parts[1], None)


# --- Simulation ---
if __name__ == "__main__":
    # Create a 5-node cluster
    nodes = [RaftNode(id=i) for i in range(5)]
    for n in nodes:
        n.peers = [p for p in nodes if p.id != n.id]

    # Simulate: N0 becomes candidate and wins election
    nodes[0].become_candidate()

    votes = 1  # self-vote
    for peer in nodes[0].peers:
        granted = peer.request_vote(
            candidate_id=nodes[0].id,
            candidate_term=nodes[0].current_term,
            last_log_index=len(nodes[0].log) - 1,
            last_log_term=nodes[0].log[-1].term if nodes[0].log else 0,
        )
        if granted:
            votes += 1

    if votes > len(nodes) / 2:
        nodes[0].state = State.LEADER
        print(f"[N0] → leader (term {nodes[0].current_term}, votes: {votes}/{len(nodes)})")

    # Leader replicates a command
    entry = LogEntry(term=nodes[0].current_term, command="SET x=42")
    nodes[0].log.append(entry)

    acks = 1
    for peer in nodes[0].peers:
        ok = peer.append_entries(
            leader_term=nodes[0].current_term,
            leader_id=nodes[0].id,
            prev_log_index=-1,
            prev_log_term=0,
            entries=[entry],
            leader_commit=nodes[0].commit_index,
        )
        if ok:
            acks += 1

    if acks > len(nodes) / 2:
        nodes[0].commit_index = 0
        nodes[0]._apply_committed()
        print(f"[N0] committed entry 0: '{entry.command}'")
        print(f"[N0] state machine: {nodes[0].kv_store}")
`;

const tsCode = `// raft.ts — Minimal Raft node (TypeScript)
// Same concepts as the Python version, typed for clarity.

enum State { Follower = "follower", Candidate = "candidate", Leader = "leader" }

interface LogEntry {
  term: number;    // which term this entry belongs to
  command: string; // the command to apply (e.g. "SET x=1")
}

interface AppendEntriesArgs {
  leaderTerm: number;
  leaderId: number;
  prevLogIndex: number; // index of log entry before new ones
  prevLogTerm: number;  // term of prevLogIndex entry
  entries: LogEntry[];
  leaderCommit: number; // leader's commitIndex
}

interface RequestVoteArgs {
  candidateTerm: number;
  candidateId: number;
  lastLogIndex: number;
  lastLogTerm: number;
}

class RaftNode {
  id: number;
  peers: RaftNode[] = [];

  // Persistent state
  currentTerm = 0;
  votedFor: number | null = null;
  log: LogEntry[] = [];

  // Volatile state
  state: State = State.Follower;
  commitIndex = -1;
  lastApplied = -1;

  // State machine
  kvStore: Map<string, string> = new Map();

  constructor(id: number) {
    this.id = id;
  }

  becomeCandidate(): void {
    this.state = State.Candidate;
    this.currentTerm++;
    this.votedFor = this.id; // vote for self
    console.log(\`[N\${this.id}] → candidate (term \${this.currentTerm})\`);
  }

  requestVote(args: RequestVoteArgs): boolean {
    const { candidateTerm, candidateId, lastLogIndex, lastLogTerm } = args;

    if (candidateTerm < this.currentTerm) return false;

    if (candidateTerm > this.currentTerm) {
      this.currentTerm = candidateTerm;
      this.votedFor = null;
      this.state = State.Follower;
    }

    if (this.votedFor !== null && this.votedFor !== candidateId) return false;

    // Log up-to-date check (§5.4.1 of the paper)
    const myLastTerm  = this.log.length > 0 ? this.log.at(-1)!.term : 0;
    const myLastIndex = this.log.length - 1;
    const logOk = lastLogTerm > myLastTerm ||
                  (lastLogTerm === myLastTerm && lastLogIndex >= myLastIndex);

    if (logOk) {
      this.votedFor = candidateId;
      return true;
    }
    return false;
  }

  appendEntries(args: AppendEntriesArgs): boolean {
    const { leaderTerm, prevLogIndex, prevLogTerm, entries, leaderCommit } = args;

    if (leaderTerm < this.currentTerm) return false;

    this.currentTerm = leaderTerm;
    this.state = State.Follower;
    this.votedFor = null;

    // Consistency check
    if (prevLogIndex >= 0) {
      if (this.log.length <= prevLogIndex) return false;
      if (this.log[prevLogIndex].term !== prevLogTerm) {
        this.log = this.log.slice(0, prevLogIndex); // truncate conflicting entries
        return false;
      }
    }

    // Append entries
    entries.forEach((entry, i) => {
      const idx = prevLogIndex + 1 + i;
      if (idx < this.log.length) {
        if (this.log[idx].term !== entry.term) {
          this.log = this.log.slice(0, idx);
          this.log.push(entry);
        }
        // else: duplicate, already have it
      } else {
        this.log.push(entry);
      }
    });

    // Advance commit and apply
    if (leaderCommit > this.commitIndex) {
      this.commitIndex = Math.min(leaderCommit, this.log.length - 1);
      this.applyCommitted();
    }

    return true;
  }

  private applyCommitted(): void {
    while (this.lastApplied < this.commitIndex) {
      this.lastApplied++;
      this.execute(this.log[this.lastApplied].command);
    }
  }

  private execute(command: string): void {
    const parts = command.split(" ");
    if (parts[0] === "SET" && parts[1]?.includes("=")) {
      const [k, v] = parts[1].split("=");
      this.kvStore.set(k, v);
    } else if (parts[0] === "DEL") {
      this.kvStore.delete(parts[1]);
    }
  }
}

// --- Simulation ---
const nodes = Array.from({ length: 5 }, (_, i) => new RaftNode(i));
nodes.forEach(n => { n.peers = nodes.filter(p => p.id !== n.id); });

// N0 runs an election
nodes[0].becomeCandidate();

let votes = 1; // self-vote
for (const peer of nodes[0].peers) {
  const granted = peer.requestVote({
    candidateTerm: nodes[0].currentTerm,
    candidateId: nodes[0].id,
    lastLogIndex: nodes[0].log.length - 1,
    lastLogTerm: nodes[0].log.at(-1)?.term ?? 0,
  });
  if (granted) votes++;
}

if (votes > nodes.length / 2) {
  nodes[0].state = State.Leader;
  console.log(\`[N0] → leader (term \${nodes[0].currentTerm}, votes: \${votes}/\${nodes.length})\`);
}

// Replicate a command
const entry: LogEntry = { term: nodes[0].currentTerm, command: "SET x=42" };
nodes[0].log.push(entry);

let acks = 1;
for (const peer of nodes[0].peers) {
  const ok = peer.appendEntries({
    leaderTerm: nodes[0].currentTerm,
    leaderId: nodes[0].id,
    prevLogIndex: -1,
    prevLogTerm: 0,
    entries: [entry],
    leaderCommit: nodes[0].commitIndex,
  });
  if (ok) acks++;
}

if (acks > nodes.length / 2) {
  nodes[0].commitIndex = 0;
  (nodes[0] as any).applyCommitted();
  console.log(\`[N0] committed: "\${entry.command}"\`);
  console.log(\`[N0] kv store:\`, Object.fromEntries(nodes[0].kvStore));
}
`;

const goCode = `// raft.go — Minimal Raft node (Go)
// Idiomatic Go: structs, methods, channels for simulation.
// Not production-ready — no real networking, no persistence.

package main

import "fmt"

// ── Types ──────────────────────────────────────────────────────────────────

type State int

const (
	Follower  State = iota
	Candidate State = iota
	Leader    State = iota
)

func (s State) String() string {
	return [...]string{"follower", "candidate", "leader"}[s]
}

type LogEntry struct {
	Term    int
	Command string
}

type RaftNode struct {
	ID    int
	Peers []*RaftNode

	// Persistent state (must survive crashes — write to disk in production)
	CurrentTerm int
	VotedFor    int // -1 means "not voted"
	Log         []LogEntry

	// Volatile state
	State       State
	CommitIndex int // highest log index known to be committed
	LastApplied int // highest log index applied to state machine

	// Leader-only (reinitialized after election)
	NextIndex  map[int]int // for each peer: next log index to send
	MatchIndex map[int]int // for each peer: highest replicated index confirmed

	// Toy state machine
	KVStore map[string]string
}

func NewNode(id int) *RaftNode {
	return &RaftNode{
		ID:          id,
		VotedFor:    -1,
		CommitIndex: -1,
		LastApplied: -1,
		NextIndex:   make(map[int]int),
		MatchIndex:  make(map[int]int),
		KVStore:     make(map[string]string),
	}
}

// ── RPCs ───────────────────────────────────────────────────────────────────

type RequestVoteArgs struct {
	CandidateTerm int
	CandidateID   int
	LastLogIndex  int
	LastLogTerm   int
}

type AppendEntriesArgs struct {
	LeaderTerm   int
	LeaderID     int
	PrevLogIndex int // index of entry before the new ones
	PrevLogTerm  int // term at PrevLogIndex
	Entries      []LogEntry
	LeaderCommit int
}

// RequestVote decides whether to grant a vote to a candidate.
func (n *RaftNode) RequestVote(args RequestVoteArgs) bool {
	if args.CandidateTerm < n.CurrentTerm {
		return false // stale candidate
	}

	// Seeing a higher term: revert to follower
	if args.CandidateTerm > n.CurrentTerm {
		n.CurrentTerm = args.CandidateTerm
		n.VotedFor = -1
		n.State = Follower
	}

	alreadyVoted := n.VotedFor != -1 && n.VotedFor != args.CandidateID
	if alreadyVoted {
		return false
	}

	// Log up-to-date check (§5.4.1)
	myLastTerm, myLastIndex := n.lastLogTermIndex()
	logOK := args.LastLogTerm > myLastTerm ||
		(args.LastLogTerm == myLastTerm && args.LastLogIndex >= myLastIndex)

	if logOK {
		n.VotedFor = args.CandidateID
		return true
	}
	return false
}

// AppendEntries handles both heartbeats (Entries=nil) and log replication.
func (n *RaftNode) AppendEntries(args AppendEntriesArgs) bool {
	if args.LeaderTerm < n.CurrentTerm {
		return false
	}

	// Valid leader — update term and revert to follower
	n.CurrentTerm = args.LeaderTerm
	n.State = Follower
	n.VotedFor = -1

	// Consistency check: does our log match at PrevLogIndex?
	if args.PrevLogIndex >= 0 {
		if len(n.Log) <= args.PrevLogIndex {
			return false // we're missing entries
		}
		if n.Log[args.PrevLogIndex].Term != args.PrevLogTerm {
			n.Log = n.Log[:args.PrevLogIndex] // delete conflicting suffix
			return false
		}
	}

	// Append new entries, skipping duplicates
	for i, entry := range args.Entries {
		idx := args.PrevLogIndex + 1 + i
		if idx < len(n.Log) {
			if n.Log[idx].Term != entry.Term {
				n.Log = n.Log[:idx] // truncate conflicting suffix
				n.Log = append(n.Log, entry)
			}
			// else: already have this entry, skip
		} else {
			n.Log = append(n.Log, entry)
		}
	}

	// Advance commit index
	if args.LeaderCommit > n.CommitIndex {
		n.CommitIndex = min(args.LeaderCommit, len(n.Log)-1)
		n.applyCommitted()
	}

	return true
}

// ── Helpers ────────────────────────────────────────────────────────────────

func (n *RaftNode) BecomeCandidate() {
	n.State = Candidate
	n.CurrentTerm++
	n.VotedFor = n.ID
	fmt.Printf("[N%d] → candidate (term %d)\\n", n.ID, n.CurrentTerm)
}

func (n *RaftNode) lastLogTermIndex() (term int, index int) {
	if len(n.Log) == 0 {
		return 0, -1
	}
	last := len(n.Log) - 1
	return n.Log[last].Term, last
}

func (n *RaftNode) applyCommitted() {
	for n.LastApplied < n.CommitIndex {
		n.LastApplied++
		n.execute(n.Log[n.LastApplied].Command)
	}
}

// execute is a toy KV state machine.
func (n *RaftNode) execute(command string) {
	var op, kv string
	fmt.Sscanf(command, "%s %s", &op, &kv)
	switch op {
	case "SET":
		var k, v string
		fmt.Sscanf(kv, "%[^=]=%s", &k, &v)
		n.KVStore[k] = v
	case "DEL":
		delete(n.KVStore, kv)
	}
}

func min(a, b int) int {
	if a < b {
		return a
	}
	return b
}

// ── Simulation ─────────────────────────────────────────────────────────────

func main() {
	// Build a 5-node cluster
	nodes := make([]*RaftNode, 5)
	for i := range nodes {
		nodes[i] = NewNode(i)
	}
	for _, n := range nodes {
		for _, p := range nodes {
			if p.ID != n.ID {
				n.Peers = append(n.Peers, p)
			}
		}
	}

	// N0 runs an election
	leader := nodes[0]
	leader.BecomeCandidate()

	votes := 1 // self-vote
	lastTerm, lastIdx := leader.lastLogTermIndex()
	for _, peer := range leader.Peers {
		if peer.RequestVote(RequestVoteArgs{
			CandidateTerm: leader.CurrentTerm,
			CandidateID:   leader.ID,
			LastLogIndex:  lastIdx,
			LastLogTerm:   lastTerm,
		}) {
			votes++
		}
	}

	if votes > len(nodes)/2 {
		leader.State = Leader
		fmt.Printf("[N%d] → leader (term %d, votes %d/%d)\\n",
			leader.ID, leader.CurrentTerm, votes, len(nodes))
	}

	// Replicate a command
	entry := LogEntry{Term: leader.CurrentTerm, Command: "SET x=42"}
	leader.Log = append(leader.Log, entry)

	acks := 1
	for _, peer := range leader.Peers {
		if peer.AppendEntries(AppendEntriesArgs{
			LeaderTerm:   leader.CurrentTerm,
			LeaderID:     leader.ID,
			PrevLogIndex: -1,
			PrevLogTerm:  0,
			Entries:      []LogEntry{entry},
			LeaderCommit: leader.CommitIndex,
		}) {
			acks++
		}
	}

	if acks > len(nodes)/2 {
		leader.CommitIndex = 0
		leader.applyCommitted()
		fmt.Printf("[N%d] committed: %q\\n", leader.ID, entry.Command)
		fmt.Printf("[N%d] kv store: %v\\n", leader.ID, leader.KVStore)
	}
}`;

const rustCode = `// raft.rs — Minimal Raft node (Rust)
// Ownership makes the state explicit: persistent fields vs volatile.
// Uses enums with derive macros and Option<u32> for nullable fields.
// Not production-ready — no async, no real networking, no persistence.

use std::collections::HashMap;

// ── Types ──────────────────────────────────────────────────────────────────

#[derive(Debug, Clone, PartialEq)]
enum State {
    Follower,
    Candidate,
    Leader,
}

#[derive(Debug, Clone)]
struct LogEntry {
    term: u32,
    command: String,
}

struct RaftNode {
    id: u32,

    // Persistent state (must be written to stable storage before responding)
    current_term: u32,
    voted_for: Option<u32>, // None = not voted this term
    log: Vec<LogEntry>,

    // Volatile state
    state: State,
    commit_index: i64, // -1 = none committed yet
    last_applied: i64,

    // Toy state machine
    kv_store: HashMap<String, String>,
}

impl RaftNode {
    fn new(id: u32) -> Self {
        RaftNode {
            id,
            current_term: 0,
            voted_for: None,
            log: Vec::new(),
            state: State::Follower,
            commit_index: -1,
            last_applied: -1,
            kv_store: HashMap::new(),
        }
    }

    // ── Core state transitions ───────────────────────────────────────────

    fn become_candidate(&mut self) {
        self.state = State::Candidate;
        self.current_term += 1;
        self.voted_for = Some(self.id); // vote for self
        println!("[N{}] → candidate (term {})", self.id, self.current_term);
    }

    // ── RPCs ─────────────────────────────────────────────────────────────

    fn request_vote(
        &mut self,
        candidate_term: u32,
        candidate_id: u32,
        last_log_index: i64,
        last_log_term: u32,
    ) -> bool {
        if candidate_term < self.current_term {
            return false; // stale candidate
        }

        // Higher term seen — revert to follower
        if candidate_term > self.current_term {
            self.current_term = candidate_term;
            self.voted_for = None;
            self.state = State::Follower;
        }

        let already_voted = matches!(self.voted_for, Some(v) if v != candidate_id);
        if already_voted {
            return false;
        }

        // Log up-to-date check (§5.4.1 of the paper)
        let (my_last_term, my_last_index) = self.last_log_term_index();
        let log_ok = last_log_term > my_last_term
            || (last_log_term == my_last_term && last_log_index >= my_last_index);

        if log_ok {
            self.voted_for = Some(candidate_id);
            true
        } else {
            false
        }
    }

    fn append_entries(
        &mut self,
        leader_term: u32,
        _leader_id: u32,
        prev_log_index: i64,
        prev_log_term: u32,
        entries: &[LogEntry],
        leader_commit: i64,
    ) -> bool {
        if leader_term < self.current_term {
            return false;
        }

        self.current_term = leader_term;
        self.state = State::Follower;
        self.voted_for = None;

        // Consistency check
        if prev_log_index >= 0 {
            let idx = prev_log_index as usize;
            if self.log.len() <= idx {
                return false; // missing entries
            }
            if self.log[idx].term != prev_log_term {
                self.log.truncate(idx); // delete conflicting suffix
                return false;
            }
        }

        // Append entries, skipping duplicates
        for (i, entry) in entries.iter().enumerate() {
            let idx = (prev_log_index + 1 + i as i64) as usize;
            if idx < self.log.len() {
                if self.log[idx].term != entry.term {
                    self.log.truncate(idx);
                    self.log.push(entry.clone());
                }
                // else: already have this entry
            } else {
                self.log.push(entry.clone());
            }
        }

        // Advance commit and apply
        if leader_commit > self.commit_index {
            self.commit_index = leader_commit.min(self.log.len() as i64 - 1);
            self.apply_committed();
        }

        true
    }

    // ── Helpers ───────────────────────────────────────────────────────────

    fn last_log_term_index(&self) -> (u32, i64) {
        match self.log.last() {
            Some(e) => (e.term, self.log.len() as i64 - 1),
            None => (0, -1),
        }
    }

    fn apply_committed(&mut self) {
        while self.last_applied < self.commit_index {
            self.last_applied += 1;
            let cmd = self.log[self.last_applied as usize].command.clone();
            self.execute(&cmd);
        }
    }

    fn execute(&mut self, command: &str) {
        let parts: Vec<&str> = command.splitn(3, ' ').collect();
        match parts.as_slice() {
            ["SET", kv] => {
                if let Some((k, v)) = kv.split_once('=') {
                    self.kv_store.insert(k.to_string(), v.to_string());
                }
            }
            ["DEL", k] => {
                self.kv_store.remove(*k);
            }
            _ => {}
        }
    }
}

// ── Simulation ─────────────────────────────────────────────────────────────
// In real Raft, nodes communicate over a network.
// Here we call methods directly to show the protocol logic clearly.

fn main() {
    let mut nodes: Vec<RaftNode> = (0..5).map(RaftNode::new).collect();

    // N0 runs an election
    nodes[0].become_candidate();

    let (last_term, last_idx) = nodes[0].last_log_term_index();
    let term = nodes[0].current_term;
    let id = nodes[0].id;

    let mut votes = 1u32; // self-vote
    // Borrow checker: collect args first, then iterate peers
    for i in 1..nodes.len() {
        let granted = nodes[i].request_vote(term, id, last_idx, last_term);
        if granted {
            votes += 1;
        }
    }

    if votes as usize > nodes.len() / 2 {
        nodes[0].state = State::Leader;
        println!(
            "[N{}] → leader (term {}, votes {}/{})",
            nodes[0].id, nodes[0].current_term, votes, nodes.len()
        );
    }

    // Replicate a command
    let entry = LogEntry {
        term: nodes[0].current_term,
        command: "SET x=42".to_string(),
    };
    nodes[0].log.push(entry.clone());

    let leader_term = nodes[0].current_term;
    let leader_id = nodes[0].id;
    let leader_commit = nodes[0].commit_index;

    let mut acks = 1u32;
    for i in 1..nodes.len() {
        let ok = nodes[i].append_entries(
            leader_term,
            leader_id,
            -1,
            0,
            &[entry.clone()],
            leader_commit,
        );
        if ok {
            acks += 1;
        }
    }

    if acks as usize > nodes.len() / 2 {
        nodes[0].commit_index = 0;
        nodes[0].apply_committed();
        println!("[N{}] committed: {:?}", nodes[0].id, entry.command);
        println!("[N{}] kv store: {:?}", nodes[0].id, nodes[0].kv_store);
    }
}`;

// Syntax highlighting with Shiki (build-time, zero runtime JS)
const [pyHtml, tsHtml, goHtml, rustHtml] = await Promise.all([
