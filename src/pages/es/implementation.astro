<script>
  // Language tab switcher
  document.querySelectorAll('.lang-tab').forEach(btn => {
    btn.addEventListener('click', () => {
      const lang = (btn as HTMLElement).dataset.lang!;

      document.querySelectorAll('.lang-tab').forEach(b => {
        b.classList.remove('active', 'bg-sky-800', 'text-sky-200', 'border-sky-600');
        b.classList.add('bg-slate-800', 'text-slate-400', 'border-slate-700');
      });
      btn.classList.add('active', 'bg-sky-800', 'text-sky-200', 'border-sky-600');
      btn.classList.remove('bg-slate-800', 'text-slate-400', 'border-slate-700');

      document.querySelectorAll('.lang-panel').forEach(p => p.classList.add('hidden'));
      document.getElementById(`code-${lang}`)?.classList.remove('hidden');
    });
  });

  // Copy buttons
  document.querySelectorAll('.copy-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const lang = (btn as HTMLElement).dataset.lang!;
      const panel = document.getElementById(`code-${lang}`);
      const code = panel?.querySelector('code')?.textContent ?? '';
      await navigator.clipboard.writeText(code);
      const svgIcon = btn.querySelector('svg')?.outerHTML ?? '';
      btn.innerHTML = svgIcon + ' Copied!';
      setTimeout(() => { btn.innerHTML = svgIcon + ' Copy'; }, 2000);
    });
  });
</script>
