---
import Base from '../../layouts/Base.astro';
import { useTranslations, localePath } from '../../i18n';
const lang = 'en';
const t = useTranslations(lang);
const base = import.meta.env.BASE_URL;
const lp = (path: string) => localePath(lang, path, base);
---
<Base title="Home" {lang} currentPath="/">

  <section class="max-w-6xl mx-auto px-4 pt-24 pb-16 text-center">
    <span class="inline-block px-3 py-1 rounded-full bg-sky-900/40 text-sky-400 text-xs font-mono mb-6 border border-sky-800">
      {t.home.badge}
    </span>
    <h1 class="text-5xl font-bold text-white mb-6 leading-tight">
      {t.home.h1a}<br />
      <span class="text-sky-400">{t.home.h1b}</span>
    </h1>
    <p class="text-xl text-slate-400 max-w-2xl mx-auto mb-10">{t.home.subtitle}</p>
    <div class="flex gap-4 justify-center">
      <a href={lp('/problem')} class="px-6 py-3 bg-sky-600 hover:bg-sky-500 text-white font-semibold rounded-lg transition">
        {t.home.cta_problem}
      </a>
      <a href={lp('/raft')} class="px-6 py-3 bg-slate-800 hover:bg-slate-700 text-slate-200 font-semibold rounded-lg transition">
        {t.home.cta_raft}
      </a>
    </div>
  </section>

  <!-- Cluster demo -->
  <section class="max-w-2xl mx-auto px-4 py-4" data-cluster-root>
    <div class="bg-slate-900 rounded-2xl border border-slate-700 p-6 flex flex-col gap-4">
      <div class="flex items-center justify-between">
        <p class="text-slate-500 text-xs font-mono">{t.home.demo_label}</p>
        <div class="flex gap-2">
          <button data-cluster="home" data-action="election"
            class="px-3 py-1.5 text-xs font-mono bg-emerald-900/50 hover:bg-emerald-800/60 text-emerald-300 rounded-lg border border-emerald-700/40 transition">
            {t.cluster.election}
          </button>
          <button data-cluster="home" data-action="kill"
            class="px-3 py-1.5 text-xs font-mono bg-red-900/50 hover:bg-red-800/60 text-red-300 rounded-lg border border-red-700/40 transition">
            {t.cluster.kill}
          </button>
          <button data-cluster="home" data-action="reset"
            class="px-3 py-1.5 text-xs font-mono bg-slate-700 hover:bg-slate-600 text-slate-300 rounded-lg transition">
            {t.cluster.reset}
          </button>
        </div>
      </div>
      <svg id="svg-home" viewBox="0 0 600 300" class="w-full" style="height:300px"
           data-cluster="home" data-node-count="5">
        <g id="edges-home"></g>
        <g id="nodes-home"></g>
        <g id="packets-home"></g>
      </svg>
      <div id="log-home" class="font-mono text-xs text-slate-400 space-y-0.5 min-h-[48px] max-h-[72px] overflow-y-auto leading-5"></div>
    </div>
  </section>

  <section class="max-w-2xl mx-auto px-4 py-3">
    <div class="flex gap-6 justify-center text-xs font-mono text-slate-500">
      <span class="flex items-center gap-1.5"><span class="w-3 h-3 rounded-full inline-block" style="background:#6366f1"></span>{t.home.legend_follower}</span>
      <span class="flex items-center gap-1.5"><span class="w-3 h-3 rounded-full inline-block" style="background:#10b981"></span>{t.home.legend_candidate}</span>
      <span class="flex items-center gap-1.5"><span class="w-3 h-3 rounded-full inline-block" style="background:#f59e0b"></span>{t.home.legend_leader}</span>
      <span class="flex items-center gap-1.5"><span class="w-3 h-3 rounded-full inline-block" style="background:#374151"></span>{t.home.legend_dead}</span>
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-4 py-16">
    <h2 class="text-2xl font-bold text-white mb-10 text-center">{t.home.learn_title}</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {t.home.cards.map((card, i) => {
        const paths = ['/problem', '/raft', '/in-the-wild', '/implementation', '/raft#safety', '/resources'];
        return (
          <a href={lp(paths[i])} class="group bg-slate-900 hover:bg-slate-800 rounded-xl border border-slate-700 hover:border-slate-600 p-6 transition">
            <div class="text-2xl mb-3">{card.icon}</div>
            <h3 class="font-semibold text-white mb-2 group-hover:text-sky-400 transition">{card.title}</h3>
            <p class="text-slate-400 text-sm leading-relaxed">{card.desc}</p>
          </a>
        );
      })}
    </div>
  </section>

  <section class="max-w-3xl mx-auto px-4 py-8 mb-8">
    <div class="bg-slate-900 rounded-xl border border-slate-700 p-6">
      <h3 class="font-semibold text-white mb-3">{t.home.paxos_title}</h3>
      <p class="text-slate-400 text-sm leading-relaxed" set:html={t.home.paxos_body} />
    </div>
  </section>
</Base>

<script>
  import { initClusters } from '../../scripts/raft-cluster';
  initClusters();
</script>
