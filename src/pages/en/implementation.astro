      <div class="space-y-2">
        <div><span class="text-yellow-400">currentTerm</span> <span class="text-slate-500">— latest term seen (increment on election)</span></div>
        <div><span class="text-yellow-400">votedFor</span>    <span class="text-slate-500">— candidateId voted for in currentTerm (or null)</span></div>
        <div><span class="text-yellow-400">log[]</span>       <span class="text-slate-500">— the replicated log: [(term, command), ...]</span></div>
        <div><span class="text-sky-400">commitIndex</span> <span class="text-slate-500">— highest index known to be committed</span></div>
        <div><span class="text-sky-400">lastApplied</span> <span class="text-slate-500">— highest index applied to state machine</span></div>
