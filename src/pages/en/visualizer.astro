---
import Base from '../../layouts/Base.astro';
import { useTranslations } from '../../i18n';
const lang = 'en';
const t = useTranslations(lang);
const tv = t.visualizer;
---
<Base title={tv.title} {lang} currentPath="/visualizer">

  <!-- Header -->
  <section class="max-w-6xl mx-auto px-4 pt-12 pb-6">
    <h1 class="text-3xl font-bold text-white mb-2">{tv.title}</h1>
    <p class="text-slate-400 text-sm max-w-2xl">{tv.subtitle}</p>
  </section>

  <!-- Controls bar -->
  <section class="max-w-6xl mx-auto px-4 pb-4">
    <div class="bg-slate-900 border border-slate-700 rounded-xl p-3 flex flex-wrap items-center gap-3">

      <!-- Playback buttons -->
      <div class="flex items-center gap-2">
        <button id="btn-step-back" class="px-3 py-1.5 text-xs font-mono bg-slate-700 hover:bg-slate-600 text-slate-300 rounded-lg border border-slate-600 transition disabled:opacity-40" disabled>
          {tv.step_back}
        </button>
        <button id="btn-play" class="px-4 py-1.5 text-xs font-mono bg-sky-700 hover:bg-sky-600 text-white rounded-lg border border-sky-600 transition">
          {tv.play}
        </button>
        <button id="btn-step-fwd" class="px-3 py-1.5 text-xs font-mono bg-slate-700 hover:bg-slate-600 text-slate-300 rounded-lg border border-slate-600 transition">
          {tv.step_fwd}
        </button>
      </div>

      <!-- Divider -->
      <div class="w-px h-6 bg-slate-700 hidden sm:block"></div>

      <!-- Speed -->
      <div class="flex items-center gap-2">
        <span class="text-slate-400 text-xs font-mono">{tv.speed}</span>
        <select id="sel-speed" class="bg-slate-800 border border-slate-600 text-slate-300 text-xs font-mono rounded-lg px-2 py-1">
          <option value="0.25">0.25×</option>
          <option value="0.5">0.5×</option>
          <option value="1" selected>1×</option>
          <option value="2">2×</option>
        </select>
      </div>

      <!-- Divider -->
      <div class="w-px h-6 bg-slate-700 hidden sm:block"></div>

      <!-- Scenario -->
      <div class="flex items-center gap-2">
        <span class="text-slate-400 text-xs font-mono">{tv.scenario_label}</span>
        <select id="sel-scenario" class="bg-slate-800 border border-slate-600 text-slate-300 text-xs font-mono rounded-lg px-2 py-1">
          <option value="normal">{tv.scenarios.normal}</option>
          <option value="leader_crash">{tv.scenarios.leader_crash}</option>
          <option value="partition">{tv.scenarios.partition}</option>
          <option value="split_vote">{tv.scenarios.split_vote}</option>
        </select>
      </div>

      <!-- Divider -->
      <div class="w-px h-6 bg-slate-700 hidden sm:block"></div>

      <!-- Node count controls -->
      <div class="flex items-center gap-2">
        <span class="text-slate-400 text-xs font-mono">Nodes</span>
        <button id="btn-remove-node" class="px-2 py-1 text-xs font-mono bg-slate-700 hover:bg-slate-600 text-slate-300 rounded border border-slate-600 transition">− Node</button>
        <span id="node-count-label" class="text-slate-300 text-xs font-mono w-4 text-center">5</span>
        <button id="btn-add-node" class="px-2 py-1 text-xs font-mono bg-slate-700 hover:bg-slate-600 text-slate-300 rounded border border-slate-600 transition">+ Node</button>
      </div>

      <!-- Divider -->
      <div class="w-px h-6 bg-slate-700 hidden sm:block"></div>

      <!-- Loop toggle -->
      <button id="btn-loop" class="px-3 py-1.5 text-xs font-mono bg-slate-700 hover:bg-slate-600 text-slate-400 rounded-lg border border-slate-600 transition">
        Loop: Off
      </button>

      <!-- Reset -->
      <div class="ml-auto">
        <button id="btn-reset" class="px-3 py-1.5 text-xs font-mono bg-red-900/40 hover:bg-red-800/50 text-red-300 rounded-lg border border-red-700/40 transition">
          {tv.reset}
        </button>
      </div>
    </div>

    <!-- Progress bar -->
    <div class="mt-2 relative">
      <div id="progress-track" class="h-3 bg-slate-800 rounded-full overflow-hidden cursor-pointer relative">
        <div id="progress-bar" class="h-full bg-sky-500 transition-none" style="width:0%"></div>
        <!-- tick marks rendered by JS -->
        <div id="progress-ticks" class="absolute inset-0 pointer-events-none"></div>
      </div>
    </div>
    <div class="mt-1 flex justify-between text-xs font-mono text-slate-600">
      <span id="progress-label">0 / 0</span>
      <span id="loop-indicator" class="text-amber-400 hidden">Looping...</span>
      <span id="time-label">t=0ms</span>
    </div>
  </section>

  <!-- Main content grid -->
  <section class="max-w-7xl mx-auto px-4 pb-12">
    <div class="grid grid-cols-1 lg:grid-cols-4 gap-4">

      <!-- Left: SVG cluster (takes 3 cols) -->
      <div class="lg:col-span-3 flex flex-col gap-4">

        <!-- SVG canvas -->
        <div class="bg-slate-900 border border-slate-700 rounded-xl p-4">
          <svg id="viz-svg" viewBox="0 0 800 460" class="w-full" style="height:460px">
            <defs>
              <filter id="glow-filter" x="-40%" y="-40%" width="180%" height="180%">
                <feGaussianBlur stdDeviation="4" result="blur"/>
                <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
              </filter>
            </defs>
            <g id="viz-edges"></g>
            <g id="viz-client"></g>
            <g id="viz-nodes"></g>
            <g id="viz-packets"></g>
            <!-- Tooltip -->
            <g id="viz-tooltip" style="display:none; pointer-events:none">
              <rect id="viz-tooltip-bg" rx="6" ry="6" fill="#0f172a" stroke="#334155" stroke-width="1.5"/>
              <text id="viz-tooltip-text" fill="#cbd5e1" font-size="11" font-family="JetBrains Mono, monospace" text-anchor="middle"></text>
            </g>
          </svg>

          <!-- Legend -->
          <div class="mt-3 flex flex-wrap gap-4 text-xs font-mono text-slate-400 px-2">
            <span class="text-slate-500 font-semibold">{tv.legend}:</span>
            <span class="flex items-center gap-1.5"><span class="w-3 h-3 rounded-full bg-indigo-500 inline-block"></span>{tv.legend_follower}</span>
            <span class="flex items-center gap-1.5"><span class="w-3 h-3 rounded-full bg-emerald-500 inline-block"></span>{tv.legend_candidate}</span>
            <span class="flex items-center gap-1.5"><span class="w-3 h-3 rounded-full bg-amber-500 inline-block"></span>{tv.legend_leader}</span>
            <span class="flex items-center gap-1.5"><span class="w-3 h-3 rounded-full bg-slate-600 inline-block"></span>{tv.legend_dead}</span>
            <span class="flex items-center gap-1.5"><span class="w-3 h-0.5 bg-indigo-400 inline-block rounded"></span>election timer</span>
          </div>
        </div>

        <!-- Narration panel -->
        <div class="bg-slate-900 border border-slate-700 rounded-xl p-4">
          <h3 class="text-xs font-mono text-slate-500 uppercase tracking-wider mb-3">{tv.narration_title}</h3>
          <div id="narration-badge" class="hidden mb-2">
            <span id="narration-type" class="px-2 py-0.5 rounded text-xs font-mono bg-sky-900/50 text-sky-300 border border-sky-700/40"></span>
          </div>
          <p id="narration-text" class="text-slate-300 text-sm leading-relaxed">{tv.narration_empty}</p>
        </div>

      </div>

      <!-- Right: Node detail + Event log (1 col) -->
      <div class="flex flex-col gap-4">

        <!-- Node detail panel -->
        <div class="bg-slate-900 border border-slate-700 rounded-xl p-4">
          <h3 class="text-xs font-mono text-slate-500 uppercase tracking-wider mb-3">{tv.node_detail_title}</h3>
          <div id="node-detail">
            <p class="text-slate-500 text-xs">{tv.node_detail_empty}</p>
          </div>
        </div>

        <!-- Event log -->
        <div class="bg-slate-900 border border-slate-700 rounded-xl p-4 flex-1">
          <h3 class="text-xs font-mono text-slate-500 uppercase tracking-wider mb-3">{tv.event_log_title}</h3>
          <div id="event-log" class="space-y-1 max-h-80 overflow-y-auto pr-1"></div>
        </div>

      </div>
    </div>
  </section>

  <!-- Terminals row: KV + Admin side by side on large screens -->
  <section class="max-w-7xl mx-auto px-4 pb-12">
    <div class="grid grid-cols-1 xl:grid-cols-2 gap-4">

  <!-- KV Store Terminal -->
    <div class="bg-black border border-slate-700 rounded-xl overflow-hidden font-mono" id="kv-terminal">
      <!-- Terminal header -->
      <div class="flex items-center gap-2 px-4 py-2.5 bg-slate-900 border-b border-slate-700">
        <span class="w-3 h-3 rounded-full bg-red-500 opacity-70"></span>
        <span class="w-3 h-3 rounded-full bg-amber-500 opacity-70"></span>
        <span class="w-3 h-3 rounded-full bg-green-500 opacity-70"></span>
        <span class="text-slate-400 text-xs ml-3">distributed-kv — connected to cluster</span>
        <span class="ml-auto text-slate-600 text-xs">type <span class="text-slate-400">help</span> for commands</span>
      </div>
      <!-- Output area -->
      <div id="kv-output" class="h-56 overflow-y-auto px-4 py-3 space-y-0.5 text-sm leading-5" style="scrollbar-color:#334155 #000"></div>
      <!-- Input line -->
      <div class="flex items-center gap-2 px-4 py-2.5 border-t border-slate-800">
        <span class="text-green-400 select-none">$</span>
        <input id="kv-input" type="text" autocomplete="off" spellcheck="false"
          class="flex-1 bg-transparent text-green-300 text-sm outline-none placeholder-slate-600 caret-green-400"
          placeholder="set key value  |  get key  |  del key  |  keys  |  state  |  help" />
      </div>
    </div>

  <!-- Cluster Admin Shell -->
    <div class="bg-black border border-red-900/50 rounded-xl overflow-hidden font-mono" id="admin-terminal">
      <!-- Terminal header -->
      <div class="flex items-center gap-2 px-4 py-2.5 bg-slate-900 border-b border-red-900/40">
        <span class="w-3 h-3 rounded-full bg-red-500 opacity-80"></span>
        <span class="w-3 h-3 rounded-full bg-amber-500 opacity-80"></span>
        <span class="w-3 h-3 rounded-full bg-green-500 opacity-50"></span>
        <span class="text-red-400/80 text-xs ml-3">cluster-admin — use with caution</span>
        <span class="ml-auto text-slate-600 text-xs">type <span class="text-slate-400">help</span> for commands</span>
      </div>
      <!-- Output area -->
      <div id="admin-output" class="h-56 overflow-y-auto px-4 py-3 space-y-0.5 text-sm leading-5" style="scrollbar-color:#334155 #000"></div>
      <!-- Input line -->
      <div class="flex items-center gap-2 px-4 py-2.5 border-t border-red-900/30">
        <span class="text-red-400 select-none font-bold">#</span>
        <input id="admin-input" type="text" autocomplete="off" spellcheck="false"
          class="flex-1 bg-transparent text-amber-200 text-sm outline-none placeholder-slate-600 caret-red-400"
          placeholder="kill N3  |  revive N3  |  partition N1,N2  |  heal  |  status" />
      </div>
    </div>

    </div><!-- end terminals grid -->
  </section>

</Base>

<script>
  import { generateScenario } from '../../scripts/raft-sim';
  import type { SimEvent, NodeState, ScenarioName } from '../../scripts/raft-sim';
  import { waapi } from 'animejs';

  // ─── Constants ────────────────────────────────────────────────────────────────

  const COLOR: Record<string, string> = {
    follower:  '#6366f1',
    candidate: '#10b981',
    leader:    '#f59e0b',
    dead:      '#374151',
  };
  const FILL_ALPHA: Record<string, string> = {
    follower:  '#6366f118',
    candidate: '#10b98118',
    leader:    '#f59e0b22',
    dead:      '#37415108',
  };

  // Packet label + color by event type
  const PACKET_LABEL: Record<string, string> = {
    request_vote:    'RV',
    vote_granted:    '✓',
    vote_denied:     '✗',
    heartbeat:       '♥',
    append_entries:  'AE',
    append_ack:      '✓',
  };
  const PACKET_COLOR: Record<string, string> = {
    request_vote:    '#10b981',  // green — vote request
    vote_granted:    '#06b6d4',  // teal — vote grant
    vote_denied:     '#ef4444',  // red
    heartbeat:       '#f59e0b',  // amber — heartbeat
    append_entries:  '#f59e0b',  // amber — AE
    append_ack:      '#38bdf8',  // blue — ack
  };

  const NODE_R = 30;
  const TIMER_R = NODE_R + 12; // radius of election timer ring
  const SVG_W = 800;
  const SVG_H = 460;
  const LANG = 'en';

  // Election timeout in ms (simulated)
  const ELECTION_TIMEOUT_MS = 2500;

  const EVENT_LABELS: Record<string, string> = {
    election_timeout: 'election timeout',
    request_vote: 'RequestVote',
    vote_granted: 'vote granted',
    vote_denied: 'vote denied',
    leader_elected: 'leader elected',
    heartbeat: 'heartbeat',
    client_request: 'client request',
    append_entries: 'AppendEntries',
    append_ack: 'append ACK',
    entry_committed: 'entry committed',
    leader_crash: 'leader crash',
    node_recover: 'node recover',
  };

  const EVENT_COLORS: Record<string, string> = {
    election_timeout: 'text-amber-300 bg-amber-900/30 border-amber-700/40',
    request_vote: 'text-emerald-300 bg-emerald-900/30 border-emerald-700/40',
    vote_granted: 'text-emerald-300 bg-emerald-900/30 border-emerald-700/40',
    vote_denied: 'text-red-300 bg-red-900/30 border-red-700/40',
    leader_elected: 'text-amber-300 bg-amber-900/30 border-amber-700/40',
    heartbeat: 'text-sky-300 bg-sky-900/30 border-sky-700/40',
    client_request: 'text-purple-300 bg-purple-900/30 border-purple-700/40',
    append_entries: 'text-sky-300 bg-sky-900/30 border-sky-700/40',
    append_ack: 'text-slate-300 bg-slate-800/50 border-slate-700/40',
    entry_committed: 'text-green-300 bg-green-900/30 border-green-700/40',
    leader_crash: 'text-red-300 bg-red-900/30 border-red-700/40',
    node_recover: 'text-indigo-300 bg-indigo-900/30 border-indigo-700/40',
  };

  // ─── State ────────────────────────────────────────────────────────────────────

  let events: SimEvent[] = [];
  let cursor = -1;
  let playing = false;
  let playTimer: ReturnType<typeof setTimeout> | null = null;
  let speedMultiplier = 1;
  let selectedNode: number | null = null;
  let nodeCount = 5;
  let looping = false;
  let loopPauseTimer: ReturnType<typeof setTimeout> | null = null;

  // Election timer animation state: maps nodeId → animation controller
  const timerAnimations: Map<number, ReturnType<typeof waapi.animate>> = new Map();

  // Admin shell: isolated node IDs (partition)
  const isolatedNodes = new Set<number>();

  // ─── DOM refs ─────────────────────────────────────────────────────────────────

  const svgEl = document.getElementById('viz-svg') as SVGSVGElement;
  const edgesG   = document.getElementById('viz-edges')   as SVGGElement;
  const clientG  = document.getElementById('viz-client')  as SVGGElement;
  const nodesG   = document.getElementById('viz-nodes')   as SVGGElement;
  const packetsG = document.getElementById('viz-packets') as SVGGElement;

  // ─── Permanent client node ────────────────────────────────────────────────────
  const CLIENT_X = SVG_W / 2;
  const CLIENT_Y = SVG_H - 36;
  const CLIENT_COLOR = '#a855f7';

  (() => {
    // Outer ring
    const ring = svgMake('circle', {
      cx: CLIENT_X, cy: CLIENT_Y, r: 22,
      fill: '#a855f708', stroke: CLIENT_COLOR,
      'stroke-width': 1.5, 'stroke-dasharray': '4 3', opacity: 0.7,
    });
    // Inner filled circle
    const dot = svgMake('circle', {
      cx: CLIENT_X, cy: CLIENT_Y, r: 14,
      fill: '#581c87', stroke: CLIENT_COLOR, 'stroke-width': 1.5,
    });
    // Label inside
    const lbl = svgMake('text', {
      x: CLIENT_X, y: CLIENT_Y + 1,
      'text-anchor': 'middle', 'dominant-baseline': 'middle',
      fill: '#d8b4fe', 'font-size': 9,
      'font-family': 'JetBrains Mono, monospace', 'font-weight': 'bold',
      'pointer-events': 'none',
    });
    lbl.textContent = 'client';
    clientG.append(ring, dot, lbl);
  })();
  const tooltipG = document.getElementById('viz-tooltip') as SVGGElement;
  const tooltipBg = document.getElementById('viz-tooltip-bg') as SVGRectElement;
  const tooltipText = document.getElementById('viz-tooltip-text') as SVGTextElement;
  const narrationText = document.getElementById('narration-text')!;
  const narrationBadge = document.getElementById('narration-badge')!;
  const narrationType = document.getElementById('narration-type')!;
  const nodeDetail = document.getElementById('node-detail')!;
  const eventLog = document.getElementById('event-log')!;
  const progressBar = document.getElementById('progress-bar')!;
  const progressTrack = document.getElementById('progress-track')!;
  const progressTicks = document.getElementById('progress-ticks')!;
  const progressLabel = document.getElementById('progress-label')!;
  const timeLabel = document.getElementById('time-label')!;
  const loopIndicator = document.getElementById('loop-indicator')!;
  const btnPlay = document.getElementById('btn-play')!;
  const btnStepBack = document.getElementById('btn-step-back') as HTMLButtonElement;
  const btnStepFwd = document.getElementById('btn-step-fwd')!;
  const btnReset = document.getElementById('btn-reset')!;
  const btnLoop = document.getElementById('btn-loop')!;
  const btnAddNode = document.getElementById('btn-add-node')!;
  const btnRemoveNode = document.getElementById('btn-remove-node')!;
  const nodeCountLabel = document.getElementById('node-count-label')!;
  const selSpeed = document.getElementById('sel-speed') as HTMLSelectElement;
  const selScenario = document.getElementById('sel-scenario') as HTMLSelectElement;

  // ─── SVG helpers ──────────────────────────────────────────────────────────────

  function svgMake<K extends keyof SVGElementTagNameMap>(tag: K, attrs: Record<string, string | number> = {}): SVGElementTagNameMap[K] {
    const el = document.createElementNS('http://www.w3.org/2000/svg', tag);
    for (const [k, v] of Object.entries(attrs)) el.setAttribute(k, String(v));
    return el;
  }

  function nodePositions(n: number): { x: number; y: number }[] {
    const cx = SVG_W / 2;
    const cy = SVG_H / 2;
    const r = Math.min(cx, cy) - NODE_R - 30;
    return Array.from({ length: n }, (_, i) => {
      const angle = (2 * Math.PI * i) / n - Math.PI / 2;
      return { x: cx + r * Math.cos(angle), y: cy + r * Math.sin(angle) };
    });
  }

  // ─── Election Timer Arcs ──────────────────────────────────────────────────────

  const timerCircumference = 2 * Math.PI * TIMER_R;

  function startTimerArc(nodeId: number, pos: { x: number; y: number }) {
    // Remove old
    stopTimerArc(nodeId);

    const arc = document.getElementById(`vtimer-${nodeId}`) as SVGCircleElement | null;
    if (!arc) return;

    // Reset to full
    arc.style.strokeDashoffset = '0';
    arc.style.opacity = '1';

    const durationMs = Math.round(ELECTION_TIMEOUT_MS / speedMultiplier);
    const anim = waapi.animate(arc, {
      strokeDashoffset: [0, timerCircumference],
      duration: durationMs,
      ease: 'linear',
      loop: true,
    });
    timerAnimations.set(nodeId, anim);
  }

  function stopTimerArc(nodeId: number) {
    const existing = timerAnimations.get(nodeId);
    if (existing) {
      try { (existing as any).pause?.(); } catch {}
      timerAnimations.delete(nodeId);
    }
    const arc = document.getElementById(`vtimer-${nodeId}`) as SVGCircleElement | null;
    if (arc) {
      arc.style.opacity = '0';
      arc.style.strokeDashoffset = '0';
    }
  }

  function updateTimerArcs(state: ReturnType<typeof generateScenario>[number]['state']) {
    for (const node of state.nodes) {
      if (node.state === 'follower') {
        const pos = nodePositions(state.nodes.length)[node.id - 1];
        if (pos) startTimerArc(node.id, pos);
      } else {
        stopTimerArc(node.id);
      }
    }
  }

  // ─── Rendering ────────────────────────────────────────────────────────────────

  function renderCluster(state: ReturnType<typeof generateScenario>[number]['state']) {
    const positions = nodePositions(state.nodes.length);

    // Edges
    edgesG.innerHTML = '';
    const alive = state.nodes.filter(n => n.state !== 'dead');
    for (let i = 0; i < alive.length; i++) {
      for (let j = i + 1; j < alive.length; j++) {
        const a = positions[alive[i].id - 1];
        const b = positions[alive[j].id - 1];
        edgesG.appendChild(svgMake('line', {
          x1: a.x, y1: a.y, x2: b.x, y2: b.y,
          stroke: '#1e293b', 'stroke-width': 1.5,
        }));
      }
    }

    // Nodes
    nodesG.innerHTML = '';
    state.nodes.forEach((node, i) => {
      const pos = positions[i];
      const g = svgMake('g', {
        id: `vnode-${node.id}`,
        style: 'cursor:pointer',
      });

      // Election timer arc (follower only)
      const timerArc = svgMake('circle', {
        cx: pos.x, cy: pos.y, r: TIMER_R,
        fill: 'none',
        stroke: '#6366f1',
        'stroke-width': 3,
        'stroke-dasharray': timerCircumference,
        'stroke-dashoffset': 0,
        'stroke-linecap': 'round',
        opacity: node.state === 'follower' ? 1 : 0,
        transform: `rotate(-90, ${pos.x}, ${pos.y})`,
        id: `vtimer-${node.id}`,
        style: 'pointer-events:none',
      });

      // Glow ring (leader only)
      const glowR = svgMake('circle', {
        cx: pos.x, cy: pos.y, r: NODE_R + 10,
        fill: 'none',
        stroke: node.state === 'leader' ? COLOR.leader : 'transparent',
        'stroke-width': 2,
        opacity: node.state === 'leader' ? 0.5 : 0,
        id: `vglow-${node.id}`,
        style: 'pointer-events:none',
      });

      const circle = svgMake('circle', {
        cx: pos.x, cy: pos.y, r: NODE_R,
        fill: FILL_ALPHA[node.state] ?? FILL_ALPHA.dead,
        stroke: selectedNode === node.id ? '#38bdf8' : (COLOR[node.state] ?? COLOR.dead),
        'stroke-width': selectedNode === node.id ? 3 : 2,
        id: `vcircle-${node.id}`,
      });

      const labelId = svgMake('text', {
        x: pos.x, y: pos.y - 6,
        'text-anchor': 'middle',
        fill: COLOR[node.state] ?? COLOR.dead,
        'font-size': 12, 'font-family': 'JetBrains Mono, monospace',
        'font-weight': 'bold',
        style: 'pointer-events:none',
      });
      labelId.textContent = `N${node.id}`;

      const labelState = svgMake('text', {
        x: pos.x, y: pos.y + 10,
        'text-anchor': 'middle',
        fill: '#64748b',
        'font-size': 9, 'font-family': 'JetBrains Mono, monospace',
        style: 'pointer-events:none',
      });
      labelState.textContent = node.state;

      const labelTerm = svgMake('text', {
        x: pos.x, y: pos.y + 22,
        'text-anchor': 'middle',
        fill: '#475569',
        'font-size': 8, 'font-family': 'JetBrains Mono, monospace',
        style: 'pointer-events:none',
      });
      labelTerm.textContent = `t${node.term}`;

      g.appendChild(timerArc);
      g.appendChild(glowR);
      g.appendChild(circle);
      g.appendChild(labelId);
      g.appendChild(labelState);
      g.appendChild(labelTerm);
      nodesG.appendChild(g);

      // Hover tooltip
      g.addEventListener('mouseenter', (e) => {
        const stateColor =
          node.state === 'leader' ? '#f59e0b' :
          node.state === 'candidate' ? '#10b981' :
          node.state === 'dead' ? '#6b7280' : '#6366f1';

        tooltipText.innerHTML = '';

        const line1 = svgMake('tspan', {
          x: pos.x, dy: 0,
          fill: stateColor, 'font-weight': 'bold',
        });
        line1.textContent = `N${node.id} · ${node.state}`;

        const line2 = svgMake('tspan', {
          x: pos.x, dy: 17,
          fill: '#94a3b8',
        });
        line2.textContent = `term ${node.term}`;

        tooltipText.appendChild(line1);
        tooltipText.appendChild(line2);

        const PAD_X = 12, PAD_Y = 8, LINE_H = 17;
        const textW = Math.max(
          `N${node.id} · ${node.state}`.length,
          `term ${node.term}`.length
        ) * 7; // ~7px per char at 11px monospace
        const tipW = textW + PAD_X * 2;
        const tipH = LINE_H + 11 + PAD_Y * 2;

        const tipX = Math.min(Math.max(pos.x, tipW / 2 + 4), SVG_W - tipW / 2 - 4);
        const above = pos.y - NODE_R - tipH - 6;
        const tipY = above >= 4 ? above : pos.y + NODE_R + 6;

        tooltipText.setAttribute('x', String(tipX));
        tooltipText.setAttribute('y', String(tipY + PAD_Y + 11));

        tooltipBg.setAttribute('x', String(tipX - tipW / 2));
        tooltipBg.setAttribute('y', String(tipY));
        tooltipBg.setAttribute('width', String(tipW));
        tooltipBg.setAttribute('height', String(tipH));

        tooltipG.style.display = '';
      });

      g.addEventListener('mouseleave', () => {
        tooltipG.style.display = 'none';
      });

      // Click: show detail panel
      g.addEventListener('click', () => {
        selectedNode = selectedNode === node.id ? null : node.id;
        renderCluster(state);
        renderNodeDetail(node);
      });

      // Animate glow for leader
      if (node.state === 'leader') {
        waapi.animate(glowR, {
          opacity: [0.5, 0.15, 0.5],
          r: [NODE_R + 10, NODE_R + 16, NODE_R + 10],
          duration: 1800,
          loop: true,
          ease: 'inOut(2)',
        });
      }
    });

    // Restart timer arcs for current state
    updateTimerArcs(state);

    // Draw partition rings for isolated nodes
    for (const node of state.nodes) {
      const nodeEl = document.getElementById(`vnode-${node.id}`);
      if (!nodeEl) continue;
      // Remove any old partition ring
      const oldRing = document.getElementById(`vpartition-${node.id}`);
      if (oldRing) oldRing.remove();
      if (isolatedNodes.has(node.id)) {
        const pos = positions[node.id - 1];
        if (!pos) continue;
        const ring = svgMake('circle', {
          cx: pos.x, cy: pos.y,
          r: NODE_R + 18,
          fill: 'none',
          stroke: '#ef4444',
          'stroke-width': 2,
          'stroke-dasharray': '6 4',
          opacity: 0.8,
          id: `vpartition-${node.id}`,
          style: 'pointer-events:none',
        });
        nodesG.appendChild(ring);
        // Dim the node visually by overlaying a semi-transparent gray
        const dimCircle = document.getElementById(`vcircle-${node.id}`);
        if (dimCircle) dimCircle.setAttribute('opacity', '0.35');
      } else {
        const dimCircle = document.getElementById(`vcircle-${node.id}`);
        if (dimCircle) dimCircle.setAttribute('opacity', '1');
      }
    }
  }

  function animatePacket(fromId: number, toId: number, color: string, label: string, state: ReturnType<typeof generateScenario>[number]['state']) {
    const positions = nodePositions(state.nodes.length);
    const from = positions[fromId - 1];
    const to = positions[toId - 1];
    if (!from || !to) return;

    const duration = Math.round(500 / speedMultiplier);

    // Main packet circle
    const packet = svgMake('circle', {
      cx: from.x, cy: from.y, r: 7,
      fill: color, opacity: 0.95,
    });

    // Trail circles for fade effect
    const trail1 = svgMake('circle', {
      cx: from.x, cy: from.y, r: 5,
      fill: color, opacity: 0.5,
    });
    const trail2 = svgMake('circle', {
      cx: from.x, cy: from.y, r: 3,
      fill: color, opacity: 0.2,
    });

    // Label text
    const pLabel = svgMake('text', {
      x: from.x, y: from.y - 12,
      'text-anchor': 'middle',
      fill: '#fff',
      'font-size': 8,
      'font-family': 'JetBrains Mono, monospace',
      'font-weight': 'bold',
      'pointer-events': 'none',
    });
    pLabel.textContent = label;

    packetsG.appendChild(trail2);
    packetsG.appendChild(trail1);
    packetsG.appendChild(packet);
    packetsG.appendChild(pLabel);

    // Animate main packet
    waapi.animate(packet, {
      cx: to.x, cy: to.y,
      duration,
      ease: 'inOut(2)',
      onComplete: () => {
        packet.remove();
        pLabel.remove();
      },
    });

    // Trails follow with delay
    waapi.animate(trail1, {
      cx: to.x, cy: to.y,
      opacity: [0.5, 0],
      duration,
      delay: 60,
      ease: 'inOut(2)',
      onComplete: () => trail1.remove(),
    });
    waapi.animate(trail2, {
      cx: to.x, cy: to.y,
      opacity: [0.2, 0],
      duration,
      delay: 120,
      ease: 'inOut(2)',
      onComplete: () => trail2.remove(),
    });

    // Animate label alongside packet
    waapi.animate(pLabel, {
      x: to.x, y: to.y - 12,
      opacity: [1, 0],
      duration,
      ease: 'inOut(2)',
    });
  }

  function flashNode(nodeId: number) {
    const circle = document.getElementById(`vcircle-${nodeId}`);
    if (!circle) return;
    waapi.animate(circle, {
      scale: [1, 1.2, 1],
      duration: 350,
      ease: 'out(3)',
    });
  }

  function flashNodeColor(nodeId: number, color: string) {
    const circle = document.getElementById(`vcircle-${nodeId}`);
    if (!circle) return;
    const origStroke = circle.getAttribute('stroke') ?? '#6366f1';
    const origFill = circle.getAttribute('fill') ?? '#6366f118';
    waapi.animate(circle, {
      stroke: [color, origStroke],
      fill: [color + '44', origFill],
      scale: [1, 1.3, 1],
      duration: 500,
      ease: 'out(3)',
    });
  }

  // ─── Event application ────────────────────────────────────────────────────────

  function applyEvent(event: SimEvent) {
    renderCluster(event.state);

    const { type, from, to, nodeId } = event;

    if (from && to) {
      const color = PACKET_COLOR[type] ?? '#38bdf8';
      const label = PACKET_LABEL[type] ?? '?';
      animatePacket(from, to, color, label, event.state);
    }

    if (nodeId && nodeId > 0) flashNode(nodeId);
    if (from) flashNode(from);

    // Reset timer for heartbeat recipients
    if (type === 'heartbeat' && to) {
      const toNode = event.state.nodes.find(n => n.id === to);
      if (toNode?.state === 'follower') {
        const pos = nodePositions(event.state.nodes.length)[to - 1];
        if (pos) startTimerArc(to, pos);
      }
    }

    // Update narration
    narrationText.textContent = event.narration[LANG];
    narrationBadge.classList.remove('hidden');
    narrationType.textContent = EVENT_LABELS[type] ?? type;
    narrationType.className = `px-2 py-0.5 rounded text-xs font-mono border ${EVENT_COLORS[type] ?? 'text-slate-300 bg-slate-800 border-slate-700'}`;

    // Update node detail if selected
    if (selectedNode !== null) {
      const nd = event.state.nodes.find(n => n.id === selectedNode);
      if (nd) renderNodeDetail(nd);
    }

    // Update progress
    updateProgress();

    // Add to event log
    addEventLogEntry(event, cursor);

    btnStepBack.disabled = cursor <= 0;
  }

  function updateProgress() {
    const pct = events.length > 0 ? ((cursor + 1) / events.length) * 100 : 0;
    progressBar.style.width = `${pct}%`;
    progressLabel.textContent = `${cursor + 1} / ${events.length}`;
    if (cursor >= 0 && cursor < events.length) {
      timeLabel.textContent = `t=${events[cursor].timestamp}ms`;
    }
  }

  function renderProgressTicks() {
    progressTicks.innerHTML = '';
    const w = progressTrack.clientWidth || 600;
    events.forEach((ev, i) => {
      const x = (i / Math.max(events.length - 1, 1)) * 100;
      const tick = document.createElement('div');
      tick.style.cssText = `position:absolute;top:0;bottom:0;left:${x}%;width:2px;background:#334155;cursor:pointer;`;
      tick.title = EVENT_LABELS[ev.type] ?? ev.type;
      tick.addEventListener('click', (e) => {
        e.stopPropagation();
        jumpTo(i);
      });
      progressTicks.appendChild(tick);
    });
  }

  function renderNodeDetail(node: NodeState) {
    const stateColor =
      node.state === 'leader' ? 'text-amber-400' :
      node.state === 'candidate' ? 'text-emerald-400' :
      node.state === 'dead' ? 'text-slate-500' : 'text-indigo-400';

    const logHtml = node.log.length === 0
      ? `<span class="text-slate-600 text-xs">(empty log)</span>`
      : node.log.map((e, idx) => `
          <div class="flex items-center gap-2 text-xs font-mono py-0.5">
            <span class="text-slate-600">[${idx}]</span>
            <span class="text-slate-400">t${e.term}</span>
            <span class="text-white">${e.command}</span>
            <span class="${e.committed ? 'text-green-500' : 'text-amber-500'}">${e.committed ? '✓' : '…'}</span>
          </div>`
      ).join('');

    nodeDetail.innerHTML = `
      <div class="space-y-2 text-xs font-mono">
        <div class="text-slate-400 text-base font-bold font-sans mb-2 text-white">N${node.id}</div>
        <div class="flex justify-between"><span class="text-slate-500">state</span><span class="${stateColor} font-semibold">${node.state}</span></div>
        <div class="flex justify-between"><span class="text-slate-500">term</span><span class="text-slate-300">${node.term}</span></div>
        <div class="flex justify-between"><span class="text-slate-500">votedFor</span><span class="text-slate-300">${node.votedFor === null ? 'none' : `N${node.votedFor}`}</span></div>
        <div class="flex justify-between"><span class="text-slate-500">commitIndex</span><span class="text-slate-300">${node.commitIndex}</span></div>
        <div class="mt-2 pt-2 border-t border-slate-700">
          <div class="text-slate-500 mb-1">log</div>
          <div class="space-y-0.5">${logHtml}</div>
        </div>
      </div>
    `;
  }

  function addEventLogEntry(event: SimEvent, idx: number) {
    const div = document.createElement('div');
    div.dataset.idx = String(idx);
    div.className = `flex items-start gap-2 p-1.5 rounded-lg cursor-pointer hover:bg-slate-800 transition text-xs`;
    div.innerHTML = `
      <span class="text-slate-600 font-mono shrink-0 mt-0.5">${String(idx + 1).padStart(2, '0')}</span>
      <span class="px-1.5 py-0.5 rounded border text-xs font-mono shrink-0 ${EVENT_COLORS[event.type] ?? 'text-slate-400 bg-slate-800 border-slate-700'}">${EVENT_LABELS[event.type] ?? event.type}</span>
      <span class="text-slate-400 leading-tight">${event.from ? `N${event.from}` : ''}${event.from && event.to ? '→' : ''}${event.to ? `N${event.to}` : ''}${event.nodeId && event.nodeId > 0 && !event.from && !event.to ? `N${event.nodeId}` : ''}</span>
      <span class="text-slate-600 font-mono ml-auto shrink-0">${event.timestamp}ms</span>
    `;
    div.addEventListener('click', () => jumpTo(idx));
    eventLog.appendChild(div);
    eventLog.scrollTop = eventLog.scrollHeight;
  }

  // ─── Timeline navigation ──────────────────────────────────────────────────────

  function jumpTo(idx: number) {
    if (idx < 0 || idx >= events.length) return;
    cursor = idx;
    eventLog.innerHTML = '';
    for (let i = 0; i <= cursor; i++) {
      addEventLogEntry(events[i], i);
    }
    applyEvent(events[cursor]);
    btnStepBack.disabled = cursor <= 0;
  }

  function stepForward() {
    if (cursor + 1 >= events.length) {
      stopPlay();
      if (looping) {
        loopIndicator.classList.remove('hidden');
        loopPauseTimer = setTimeout(() => {
          loopIndicator.classList.add('hidden');
          reset(false); // don't re-load scenario, just rewind
          startPlay();
        }, 3000);
      }
      return;
    }
    cursor++;
    applyEvent(events[cursor]);
  }

  function stepBack() {
    if (cursor <= 0) return;
    cursor--;
    eventLog.innerHTML = '';
    for (let i = 0; i <= cursor; i++) {
      addEventLogEntry(events[i], i);
    }
    applyEvent(events[cursor]);
  }

  // ─── Playback ─────────────────────────────────────────────────────────────────

  function scheduleNext() {
    if (!playing) return;
    if (cursor + 1 >= events.length) {
      stopPlay();
      if (looping) {
        loopIndicator.classList.remove('hidden');
        loopPauseTimer = setTimeout(() => {
          loopIndicator.classList.add('hidden');
          reset(false);
          startPlay();
        }, 3000);
      }
      return;
    }

    const next = events[cursor + 1];
    const current = cursor >= 0 ? events[cursor] : { timestamp: 0 };
    // Minimum 500ms hold between events for readability
    const rawDelay = (next.timestamp - current.timestamp) / speedMultiplier;
    const delay = Math.max(500 / speedMultiplier, rawDelay);

    playTimer = setTimeout(() => {
      stepForward();
      scheduleNext();
    }, delay);
  }

  function startPlay() {
    if (playing) return;
    playing = true;
    btnPlay.textContent = 'Pause';
    btnPlay.className = 'px-4 py-1.5 text-xs font-mono bg-slate-700 hover:bg-slate-600 text-slate-300 rounded-lg border border-slate-600 transition';
    scheduleNext();
  }

  function stopPlay() {
    playing = false;
    if (playTimer) { clearTimeout(playTimer); playTimer = null; }
    if (loopPauseTimer) { clearTimeout(loopPauseTimer); loopPauseTimer = null; }
    loopIndicator.classList.add('hidden');
    btnPlay.textContent = 'Play';
    btnPlay.className = 'px-4 py-1.5 text-xs font-mono bg-sky-700 hover:bg-sky-600 text-white rounded-lg border border-sky-600 transition';
  }

  function reset(reloadScenario = true) {
    // Cancel all timer animations
    for (const [id] of timerAnimations) {
      stopTimerArc(id);
    }
    timerAnimations.clear();

    if (reloadScenario) {
      stopPlay();
    }
    cursor = -1;
    selectedNode = null;
    eventLog.innerHTML = '';
    narrationBadge.classList.add('hidden');
    narrationText.textContent = 'Press Play or Step Forward to start the simulation.';
    nodeDetail.innerHTML = '<p class="text-slate-500 text-xs">Click a node to inspect its state.</p>';
    progressBar.style.width = '0%';
    progressLabel.textContent = `0 / ${events.length}`;
    timeLabel.textContent = 't=0ms';
    btnStepBack.disabled = true;
    packetsG.innerHTML = '';

    if (events.length > 0) {
      renderCluster(events[0].state);
      renderProgressTicks();
    }
  }

  function loadScenario(name: ScenarioName) {
    stopPlay();
    events = generateScenario(name, nodeCount);
    reset(false);
  }

  // ─── Init ─────────────────────────────────────────────────────────────────────

  loadScenario('normal');

  // ─── Event listeners ──────────────────────────────────────────────────────────

  btnPlay.addEventListener('click', () => {
    if (playing) stopPlay();
    else startPlay();
  });

  btnStepFwd.addEventListener('click', () => {
    stopPlay();
    stepForward();
  });

  btnStepBack.addEventListener('click', () => {
    stopPlay();
    stepBack();
  });

  btnReset.addEventListener('click', () => {
    loadScenario(selScenario.value as ScenarioName);
  });

  selScenario.addEventListener('change', () => {
    loadScenario(selScenario.value as ScenarioName);
  });

  selSpeed.addEventListener('change', () => {
    speedMultiplier = parseFloat(selSpeed.value);
    // Restart timer arcs at new speed if we have a current state
    if (cursor >= 0) {
      updateTimerArcs(events[cursor].state);
    }
  });

  btnLoop.addEventListener('click', () => {
    looping = !looping;
    btnLoop.textContent = `Loop: ${looping ? 'On' : 'Off'}`;
    btnLoop.className = looping
      ? 'px-3 py-1.5 text-xs font-mono bg-amber-900/40 hover:bg-amber-800/50 text-amber-300 rounded-lg border border-amber-700/40 transition'
      : 'px-3 py-1.5 text-xs font-mono bg-slate-700 hover:bg-slate-600 text-slate-400 rounded-lg border border-slate-600 transition';
  });

  btnAddNode.addEventListener('click', () => {
    if (nodeCount >= 9) return;
    nodeCount++;
    nodeCountLabel.textContent = String(nodeCount);
    loadScenario(selScenario.value as ScenarioName);
  });

  btnRemoveNode.addEventListener('click', () => {
    if (nodeCount <= 3) return;
    nodeCount--;
    nodeCountLabel.textContent = String(nodeCount);
    loadScenario(selScenario.value as ScenarioName);
  });

  // Progress bar click to jump
  progressTrack.addEventListener('click', (e: MouseEvent) => {
    const rect = progressTrack.getBoundingClientRect();
    const pct = (e.clientX - rect.left) / rect.width;
    const idx = Math.min(events.length - 1, Math.floor(pct * events.length));
    if (idx >= 0) jumpTo(idx);
  });

  // ─── KV Terminal ──────────────────────────────────────────────────────────────

  const kvStore = new Map<string, string>();
  const kvOutput = document.getElementById('kv-output')!;
  const kvInput = document.getElementById('kv-input') as HTMLInputElement;
  const kvTerminal = document.getElementById('kv-terminal')!;
  const MAX_SCROLLBACK = 50;

  function kvPrint(line: string, cls = 'text-slate-300') {
    const div = document.createElement('div');
    div.className = `font-mono text-sm whitespace-pre ${cls}`;
    div.textContent = line;
    kvOutput.appendChild(div);
    // Trim scrollback
    while (kvOutput.children.length > MAX_SCROLLBACK) {
      kvOutput.removeChild(kvOutput.firstChild!);
    }
    kvOutput.scrollTop = kvOutput.scrollHeight;
  }

  function kvCurrentLeader(): { id: number; nodeCount: number } | null {
    if (cursor < 0 || cursor >= events.length) return null;
    const state = events[cursor].state;
    const leader = state.nodes.find(n => n.state === 'leader');
    if (!leader) return null;
    return { id: leader.id, nodeCount: state.nodes.length };
  }

  // Spawn a comet-style packet between two SVG points (not node-to-node, but coord-to-coord)
  function kvSpawnPacket(
    fromX: number, fromY: number,
    toX: number, toY: number,
    color: string, label: string,
    delay: number,
    onDone?: () => void,
  ) {
    const dur = Math.round(500 / speedMultiplier);

    const pkt = svgMake('circle', { cx: fromX, cy: fromY, r: 7, fill: color, opacity: 0.95 });
    const t1  = svgMake('circle', { cx: fromX, cy: fromY, r: 5, fill: color, opacity: 0.5 });
    const t2  = svgMake('circle', { cx: fromX, cy: fromY, r: 3, fill: color, opacity: 0.22 });
    const lbl = svgMake('text', {
      x: fromX, y: fromY - 11,
      'text-anchor': 'middle', fill: '#fff',
      'font-size': 8, 'font-family': 'JetBrains Mono, monospace',
      'font-weight': 'bold', 'pointer-events': 'none',
    });
    lbl.textContent = label;
    packetsG.append(t2, t1, pkt, lbl);

    const ease = 'inOut(2)';
    waapi.animate(pkt, { cx: toX, cy: toY, duration: dur, delay, ease, onComplete: () => { pkt.remove(); onDone?.(); } });
    waapi.animate(t1,  { cx: toX, cy: toY, duration: dur, delay: delay + 60, ease, onComplete: () => t1.remove() });
    waapi.animate(t2,  { cx: toX, cy: toY, duration: dur, delay: delay + 120, ease, onComplete: () => t2.remove() });
    waapi.animate(lbl, { x: toX, y: toY - 11, opacity: [1, 0], duration: dur, delay, ease, onComplete: () => lbl.remove() });
  }

  function kvAnimateWrite(leaderId: number, followerIds: number[], onDone?: () => void) {
    if (cursor < 0 || cursor >= events.length) return;
    const state = events[cursor].state;
    const positions = nodePositions(state.nodes.length);
    const leaderPos = positions[leaderId - 1];
    if (!leaderPos) return;

    const clientX = CLIENT_X;
    const clientY = CLIENT_Y;
    const ACK_COLOR = '#22d3ee';

    // 1. Client → leader (purple "write")
    kvSpawnPacket(clientX, clientY, leaderPos.x, leaderPos.y, CLIENT_COLOR, 'write', 0, () => {
      flashNode(leaderId);

      // 2. Leader → each follower (amber AppendEntries), staggered
      let completed = 0;
      followerIds.forEach((fid, i) => {
        const fPos = positions[fid - 1];
        if (!fPos) return;
        const stagger = i * 60;
        kvSpawnPacket(leaderPos.x, leaderPos.y, fPos.x, fPos.y, '#f59e0b', 'AE', stagger, () => {
          flashNode(fid);
          // 3. Each follower → leader ACK (teal)
          kvSpawnPacket(fPos.x, fPos.y, leaderPos.x, leaderPos.y, ACK_COLOR, '✓', 0, () => {
            completed++;
            if (completed === followerIds.length) {
              // 4. Leader → client commit confirmation (green)
              kvSpawnPacket(leaderPos.x, leaderPos.y, clientX, clientY, '#4ade80', 'ok', 0, onDone);
              flashNode(leaderId);
            }
          });
        });
      });

      // Edge case: no followers
      if (followerIds.length === 0) {
        kvSpawnPacket(leaderPos.x, leaderPos.y, clientX, clientY, '#4ade80', 'ok', 0, onDone);
      }
    });

    // Pulse the permanent client node to show activity
    const clientNodeDot = clientG.querySelector('circle:nth-child(2)') as SVGCircleElement | null;
    if (clientNodeDot) {
      waapi.animate(clientNodeDot, {
        r: [14, 18, 14], opacity: [1, 0.6, 1],
        duration: 600, loop: 2,
      });
    }
  }

  async function kvExecWrite(op: 'SET' | 'DEL', key: string, value?: string): Promise<void> {
    const leader = kvCurrentLeader();
    if (!leader) {
      kvPrint('  ✗ no leader — cluster unavailable', 'text-red-400');
      return;
    }

    // Validate DEL before animating
    if (op === 'DEL' && !kvStore.has(key)) {
      kvPrint(`  ✗ key not found: ${key}`, 'text-amber-400');
      return;
    }

    const command = op === 'SET' ? `SET ${key}=${value}` : `DEL ${key}`;
    kvPrint(`  → leader N${leader.id} received ${op} ${op === 'SET' ? `${key} = ${value}` : key}`, 'text-sky-300');

    // ── Step 1: append entry (pending) to all live nodes ──────────────────────
    const idx = events[cursor < 0 ? 0 : cursor];
    const liveState = idx.state;
    const leaderNode = liveState.nodes.find(n => n.id === leader.id)!;
    const newTerm = leaderNode.term;
    const newEntry = { term: newTerm, command, committed: false };

    liveState.nodes.forEach(n => {
      if (n.state !== 'dead') n.log.push({ ...newEntry });
    });
    renderCluster(liveState);

    const followers = liveState.nodes.filter(n => n.state === 'follower').map(n => n.id);
    const majority = Math.floor(liveState.nodes.length / 2) + 1;

    // ── Step 2: animate client→leader→followers→ACKs→commit ──────────────────
    await new Promise<void>(resolve => {
      kvAnimateWrite(leader.id, followers, resolve);
    });

    kvPrint(`  → replicating to ${followers.map(id => `N${id}`).join(', ')}...`, 'text-sky-300');
    await new Promise(r => setTimeout(r, 120));
    kvPrint(`  → majority ACK (${majority}/${liveState.nodes.length})`, 'text-sky-300');
    await new Promise(r => setTimeout(r, 80));

    // ── Step 3: commit — mark entry committed on all live nodes ──────────────
    liveState.nodes.forEach(n => {
      if (n.state !== 'dead') {
        const entry = n.log[n.log.length - 1];
        if (entry && !entry.committed && entry.command === command) {
          entry.committed = true;
          n.commitIndex = n.log.length - 1;
        }
      }
    });

    if (op === 'SET') {
      kvStore.set(key, value!);
      kvPrint(`  ✓ committed: ${key} = ${value}`, 'text-green-400');
    } else {
      kvStore.delete(key);
      kvPrint(`  ✓ committed: deleted ${key}`, 'text-green-400');
    }

    // ── Step 4: re-render cluster + refresh selected node detail ─────────────
    renderCluster(liveState);
    if (selectedNode !== null) {
      const nd = liveState.nodes.find(n => n.id === selectedNode);
      if (nd) renderNodeDetail(nd);
    }
  }

  async function kvHandleCommand(raw: string) {
    const trimmed = raw.trim();
    if (!trimmed) return;

    // Echo input
    kvPrint(`$ ${trimmed}`, 'text-green-300');

    const parts = trimmed.split(/\s+/);
    const cmd = parts[0].toLowerCase();

    if (cmd === 'clear') {
      kvOutput.innerHTML = '';
      return;
    }

    if (cmd === 'help') {
      kvPrint('  Commands:', 'text-slate-400');
      kvPrint('    set <key> <value>   — write a key', 'text-slate-400');
      kvPrint('    get <key>           — read a key from leader', 'text-slate-400');
      kvPrint('    del <key>           — delete a key', 'text-slate-400');
      kvPrint('    keys                — list all committed keys', 'text-slate-400');
      kvPrint('    state               — show cluster state', 'text-slate-400');
      kvPrint('    clear               — clear terminal', 'text-slate-400');
      kvPrint('    help                — this message', 'text-slate-400');
      return;
    }

    if (cmd === 'keys') {
      if (kvStore.size === 0) {
        kvPrint('  (empty store)', 'text-slate-500');
      } else {
        for (const [k, v] of kvStore) {
          kvPrint(`  ${k} = ${v}`, 'text-slate-300');
        }
      }
      return;
    }

    if (cmd === 'state') {
      if (cursor < 0 || cursor >= events.length) {
        kvPrint('  (simulation not started)', 'text-slate-500');
        return;
      }
      const state = events[cursor].state;
      kvPrint(`  cluster term: ${state.term}`, 'text-slate-300');
      for (const n of state.nodes) {
        const role = n.state === 'leader' ? ' [LEADER]' : n.state === 'dead' ? ' [DEAD]' : '';
        kvPrint(`  N${n.id}: ${n.state}${role}  term=${n.term}  log=${n.log.length}  commit=${n.commitIndex}`, 'text-slate-300');
      }
      return;
    }

    if (cmd === 'get') {
      const key = parts[1];
      if (!key) { kvPrint('  usage: get <key>', 'text-amber-400'); return; }
      const leader = kvCurrentLeader();
      if (!leader) { kvPrint('  ✗ no leader — cluster unavailable', 'text-red-400'); return; }
      kvPrint(`  → reading from leader N${leader.id}`, 'text-sky-300');
      if (kvStore.has(key)) {
        kvPrint(`  ${key} = ${kvStore.get(key)}`, 'text-green-300');
      } else {
        kvPrint(`  ✗ key not found: ${key}`, 'text-amber-400');
      }
      return;
    }

    if (cmd === 'set') {
      const key = parts[1];
      const value = parts.slice(2).join(' ');
      if (!key || !value) { kvPrint('  usage: set <key> <value>', 'text-amber-400'); return; }
      await kvExecWrite('SET', key, value);
      return;
    }

    if (cmd === 'del') {
      const key = parts[1];
      if (!key) { kvPrint('  usage: del <key>', 'text-amber-400'); return; }
      await kvExecWrite('DEL', key);
      return;
    }

    kvPrint(`  ✗ unknown command: ${cmd}  (type help)`, 'text-red-400');
  }

  // Startup message
  kvPrint('  distributed-kv v1.0  —  Raft-backed key/value store', 'text-slate-500');
  kvPrint('  type help for available commands', 'text-slate-500');
  kvPrint('  use the cluster-admin shell below to kill/revive nodes or create partitions', 'text-slate-600');

  // Focus input on terminal click
  kvTerminal.addEventListener('click', () => kvInput.focus());

  // Handle Enter
  kvInput.addEventListener('keydown', async (e: KeyboardEvent) => {
    if (e.key !== 'Enter') return;
    const val = kvInput.value;
    kvInput.value = '';
    await kvHandleCommand(val);
  });

  // ─── Cluster Admin Shell ──────────────────────────────────────────────────────

  const adminOutput = document.getElementById('admin-output')!;
  const adminInput  = document.getElementById('admin-input') as HTMLInputElement;
  const adminTerminal = document.getElementById('admin-terminal')!;
  const ADMIN_MAX_SCROLLBACK = 80;

  function adminPrint(line: string, cls = 'text-amber-100/80') {
    const div = document.createElement('div');
    div.className = `font-mono text-sm whitespace-pre ${cls}`;
    div.textContent = line;
    adminOutput.appendChild(div);
    while (adminOutput.children.length > ADMIN_MAX_SCROLLBACK) {
      adminOutput.removeChild(adminOutput.firstChild!);
    }
    adminOutput.scrollTop = adminOutput.scrollHeight;
  }

  function adminGetState() {
    if (cursor < 0 || cursor >= events.length) return null;
    return events[cursor].state;
  }

  function adminParseNodeId(raw: string): number | null {
    const m = raw.trim().toUpperCase().match(/^N?(\d+)$/);
    if (!m) return null;
    return parseInt(m[1], 10);
  }

  async function adminHandleCommand(raw: string) {
    const trimmed = raw.trim();
    if (!trimmed) return;

    adminPrint(`# ${trimmed}`, 'text-red-300');

    const parts = trimmed.split(/[\s,]+/).filter(Boolean);
    const cmd = parts[0].toLowerCase();

    if (cmd === 'clear') {
      adminOutput.innerHTML = '';
      return;
    }

    if (cmd === 'help') {
      adminPrint('  Commands:', 'text-slate-400');
      adminPrint('    kill <nodeId>          — crash a node (e.g. kill N3)', 'text-slate-400');
      adminPrint('    revive <nodeId>        — bring a dead node back as follower', 'text-slate-400');
      adminPrint('    partition <ids>        — isolate nodes (e.g. partition N1,N2)', 'text-slate-400');
      adminPrint('    heal                   — remove all partitions', 'text-slate-400');
      adminPrint('    quorum                 — quorum status', 'text-slate-400');
      adminPrint('    leader                 — current leader and term', 'text-slate-400');
      adminPrint('    term                   — current cluster term', 'text-slate-400');
      adminPrint('    logs                   — log lengths for all nodes', 'text-slate-400');
      adminPrint('    status                 — full cluster overview', 'text-slate-400');
      adminPrint('    clear                  — clear terminal', 'text-slate-400');
      adminPrint('    help                   — this message', 'text-slate-400');
      return;
    }

    if (cmd === 'kill') {
      const id = adminParseNodeId(parts[1] ?? '');
      if (!id) { adminPrint('  usage: kill <nodeId>  (e.g. kill N3)', 'text-amber-400'); return; }
      const state = adminGetState();
      if (!state) { adminPrint('  simulation not started', 'text-slate-500'); return; }
      const node = state.nodes.find(n => n.id === id);
      if (!node) { adminPrint(`  N${id} not found`, 'text-red-400'); return; }
      if (node.state === 'dead') { adminPrint(`  N${id} is already dead`, 'text-amber-400'); return; }
      const wasLeader = node.state === 'leader';
      // Flash red before going dead
      flashNodeColor(id, '#ef4444');
      await new Promise(r => setTimeout(r, 300));
      node.state = 'dead';
      stopTimerArc(id);
      renderCluster(state);
      adminPrint(`  N${id} killed`, 'text-red-400');
      if (wasLeader) adminPrint('  ⚠ leader is down — a new election will be needed', 'text-amber-300');
      return;
    }

    if (cmd === 'revive') {
      const id = adminParseNodeId(parts[1] ?? '');
      if (!id) { adminPrint('  usage: revive <nodeId>  (e.g. revive N3)', 'text-amber-400'); return; }
      const state = adminGetState();
      if (!state) { adminPrint('  simulation not started', 'text-slate-500'); return; }
      const node = state.nodes.find(n => n.id === id);
      if (!node) { adminPrint(`  N${id} not found`, 'text-red-400'); return; }
      if (node.state !== 'dead') { adminPrint(`  N${id} is not dead (state: ${node.state})`, 'text-amber-400'); return; }
      node.state = 'follower';
      renderCluster(state);
      flashNodeColor(id, '#22c55e');
      adminPrint(`  N${id} revived as follower (term ${node.term})`, 'text-green-400');
      return;
    }

    if (cmd === 'partition') {
      const ids = parts.slice(1).map(p => adminParseNodeId(p)).filter(Boolean) as number[];
      if (ids.length === 0) { adminPrint('  usage: partition N1,N2  (comma or space separated)', 'text-amber-400'); return; }
      const state = adminGetState();
      if (!state) { adminPrint('  simulation not started', 'text-slate-500'); return; }
      for (const id of ids) {
        if (!state.nodes.find(n => n.id === id)) {
          adminPrint(`  N${id} not found — skipped`, 'text-amber-400');
          continue;
        }
        isolatedNodes.add(id);
        adminPrint(`  N${id} isolated — packets to/from this node will be dropped`, 'text-red-400');
      }
      renderCluster(state);
      return;
    }

    if (cmd === 'heal') {
      const state = adminGetState();
      if (isolatedNodes.size === 0) { adminPrint('  no active partitions', 'text-slate-500'); return; }
      const healed = [...isolatedNodes].map(id => `N${id}`).join(', ');
      isolatedNodes.clear();
      if (state) renderCluster(state);
      adminPrint(`  partition healed — restored: ${healed}`, 'text-green-400');
      return;
    }

    if (cmd === 'quorum') {
      const state = adminGetState();
      if (!state) { adminPrint('  simulation not started', 'text-slate-500'); return; }
      const total = state.nodes.length;
      const alive = state.nodes.filter(n => n.state !== 'dead').length;
      const majority = Math.floor(total / 2) + 1;
      const hasQuorum = alive >= majority;
      adminPrint(`  total nodes : ${total}`, 'text-slate-300');
      adminPrint(`  alive       : ${alive}`, 'text-slate-300');
      adminPrint(`  majority    : ${majority}`, 'text-slate-300');
      adminPrint(`  quorum      : ${hasQuorum ? 'YES' : 'NO'}`, hasQuorum ? 'text-green-400' : 'text-red-400');
      return;
    }

    if (cmd === 'leader') {
      const state = adminGetState();
      if (!state) { adminPrint('  simulation not started', 'text-slate-500'); return; }
      const leader = state.nodes.find(n => n.state === 'leader');
      if (!leader) { adminPrint('  no leader — cluster in election or all dead', 'text-red-400'); return; }
      adminPrint(`  leader: N${leader.id}  (term ${leader.term})`, 'text-amber-300');
      return;
    }

    if (cmd === 'term') {
      const state = adminGetState();
      if (!state) { adminPrint('  simulation not started', 'text-slate-500'); return; }
      adminPrint(`  cluster term: ${state.term}`, 'text-slate-300');
      return;
    }

    if (cmd === 'logs') {
      const state = adminGetState();
      if (!state) { adminPrint('  simulation not started', 'text-slate-500'); return; }
      adminPrint('  node   log   commitIndex  state', 'text-slate-500');
      adminPrint('  ──────────────────────────────', 'text-slate-700');
      for (const n of state.nodes) {
        const row = `  N${String(n.id).padEnd(4)} ${String(n.log.length).padEnd(5)}  ${String(n.commitIndex).padEnd(11)}  ${n.state}`;
        const cls = n.state === 'dead' ? 'text-slate-500' : n.state === 'leader' ? 'text-amber-300' : 'text-slate-300';
        adminPrint(row, cls);
      }
      return;
    }

    if (cmd === 'status') {
      const state = adminGetState();
      if (!state) { adminPrint('  simulation not started', 'text-slate-500'); return; }
      const leader = state.nodes.find(n => n.state === 'leader');
      const total = state.nodes.length;
      const alive = state.nodes.filter(n => n.state !== 'dead').length;
      const majority = Math.floor(total / 2) + 1;
      const hasQuorum = alive >= majority;
      adminPrint(`  cluster term : ${state.term}`, 'text-slate-300');
      adminPrint(`  leader       : ${leader ? `N${leader.id} (term ${leader.term})` : 'none'}`, leader ? 'text-amber-300' : 'text-red-400');
      adminPrint(`  quorum       : ${alive}/${total} alive — majority ${majority} — ${hasQuorum ? 'OK' : 'LOST'}`, hasQuorum ? 'text-green-400' : 'text-red-400');
      if (isolatedNodes.size > 0) {
        adminPrint(`  partitioned  : ${[...isolatedNodes].map(id => `N${id}`).join(', ')}`, 'text-red-400');
      }
      adminPrint('  ──────────────────────────────', 'text-slate-700');
      for (const n of state.nodes) {
        const isolated = isolatedNodes.has(n.id) ? ' [ISOLATED]' : '';
        const row = `  N${n.id}: ${n.state}${isolated}  term=${n.term}  log=${n.log.length}  commit=${n.commitIndex}`;
        const cls = n.state === 'dead' ? 'text-slate-500' : n.state === 'leader' ? 'text-amber-300' : isolatedNodes.has(n.id) ? 'text-red-300' : 'text-slate-300';
        adminPrint(row, cls);
      }
      return;
    }

    adminPrint(`  unknown command: ${cmd}  (type help)`, 'text-red-400');
  }

  // Admin startup message
  adminPrint('  cluster-admin v1.0  —  elevated cluster control', 'text-slate-500');
  adminPrint('  ⚠ mutations apply to live simulation state', 'text-amber-900/60');
  adminPrint('  type help for available commands', 'text-slate-600');

  adminTerminal.addEventListener('click', () => adminInput.focus());

  adminInput.addEventListener('keydown', async (e: KeyboardEvent) => {
    if (e.key !== 'Enter') return;
    const val = adminInput.value;
    adminInput.value = '';
    await adminHandleCommand(val);
  });
</script>
