---
// Root redirect — detect browser language and redirect to /en or /es
---
<html>
  <head>
    <meta charset="UTF-8" />
    <script is:inline>
      const base = '/distributed-consensus-learning';
      const lang = navigator.language?.startsWith('es') ? 'es' : 'en';
      window.location.replace(`${base}/${lang}/`);
    </script>
    <!-- Fallback for no-JS -->
    <meta http-equiv="refresh" content="0; url=/distributed-consensus-learning/en/" />
  </head>
  <body></body>
</html>
